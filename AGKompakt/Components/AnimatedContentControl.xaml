<UserControl
    x:Class="BGH_Kompakt.Components.AnimatedContentControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid Grid.Row="1">
            <MW:MetroAnimatedTabControl>
                <MW:MetroTabItem Name="MetroTabItem">
                    <ContentControl Name="PagePlace" Background="Red" />
                </MW:MetroTabItem>
            </MW:MetroAnimatedTabControl>
        </Grid>
    </Grid>
</UserControl>
