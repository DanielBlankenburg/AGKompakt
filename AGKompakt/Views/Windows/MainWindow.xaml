<MW:MetroWindow
    x:Class="BGH_Kompakt.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Ctrl="clr-namespace:BGH_Kompakt.Components"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:BGH_Kompakt.ViewModel"
    xmlns:mainwindow="clr-namespace:BGH_Kompakt.ViewModel.MainWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="BGH-Kompakt"
    Width="1800"
    Height="800"
    MinWidth="1200"
    MinHeight="700"
    d:DataContext="{d:DesignInstance Type=mainwindow:MainWindowViewModel}"
    Loaded="MetroWindow_Loaded"
    SaveWindowPosition="true"
    SnapsToDevicePixels="true"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">

    <MW:MetroWindow.Flyouts>
        <MW:FlyoutsControl>

            <MW:Flyout
                x:Name="InfoFlyout"
                AutoCloseInterval="7000"
                Background="{StaticResource BGH-FlyoutColor}"
                CloseButtonVisibility="Collapsed"
                IsAutoCloseEnabled="True"
                Position="Bottom"
                TitleVisibility="Collapsed">
                <Grid
                    Height="Auto"
                    HorizontalAlignment="Left"
                    Background="{StaticResource BGH-FlyoutColor}">
                    <StackPanel
                        Margin="0,0,50,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{StaticResource BGH-FlyoutColor}"
                        Orientation="Horizontal">
                        <MD:PackIcon
                            Name="FlyoutInfoIcon"
                            Width="40"
                            Height="40"
                            Margin="0,5,0,5"
                            VerticalAlignment="Top"
                            Foreground="White"
                            Kind="InformationCircle" />
                        <TextBlock
                            Name="LblFlyoutInfo"
                            MaxWidth="{Binding Width, RelativeSource={RelativeSource AncestorType={x:Type MW:MetroWindow}, Mode=FindAncestor}}"
                            Margin="10,5,0,5"
                            Background="Transparent"
                            FontSize="26"
                            FontWeight="Normal"
                            Foreground="White"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Button
                        x:Name="BtnCloseFlyoutInfo"
                        Height="42"
                        Margin="0,5,-10,5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        BorderBrush="White"
                        BorderThickness="1"
                        Cursor="Hand"
                        Style="{StaticResource MahApps.Styles.Button.Circle}"
                        ToolTip="SCHLIEßEN">
                        <MD:PackIcon
                            Width="40"
                            Height="40"
                            Foreground="White"
                            Kind="ArrowDownBoldCircle" />

                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:ChangePropertyAction
                                    PropertyName="IsOpen"
                                    TargetName="InfoFlyout"
                                    Value="False" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </Grid>
            </MW:Flyout>
        </MW:FlyoutsControl>
    </MW:MetroWindow.Flyouts>
    <MW:MetroWindow.RightWindowCommands>
        <MW:WindowCommands>
            <StackPanel Orientation="Horizontal">
                <Button
                    x:Name="Btn_UserLogin"
                    Margin="0,1,0,0"
                    Click="Btn_UserLogin_Click"
                    Style="{StaticResource Style_Button_Sitzungsunterlagen_Neu}">
                    <StackPanel Orientation="Horizontal">
                        <MD:PackIcon Kind="Account" Style="{StaticResource MD_SignDiscription}" />
                        <TextBlock
                            Margin="10,0,10,0"
                            d:Text="User"
                            FontFamily="{StaticResource MaterialDesignFont}"
                            Foreground="White"
                            Text="{Binding LoginUser}" />
                    </StackPanel>
                </Button>
                <ComboBox
                    DisplayMemberPath="SenatName"
                    FontFamily="{StaticResource MaterialDesignFont}"
                    ItemsSource="{Binding SenatList, UpdateSourceTrigger=PropertyChanged}"
                    SelectedItem="{Binding SelectedSenat}"
                    Style="{StaticResource Combobox_WindowCommand}" />
            </StackPanel>
        </MW:WindowCommands>
    </MW:MetroWindow.RightWindowCommands>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="20*" />
        </Grid.ColumnDefinitions>
        <Grid Background="{StaticResource BGH-Color}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!--  Bild des BGH  -->
            <Image
                x:Name="BGH"
                Grid.Row="0"
                DockPanel.Dock="Top"
                Source="/Resources/ImageResources/Images/Amtsgericht-Hannover.jpg" />
            <!--  Versionangaben  -->
            <Border
                Grid.Row="2"
                Padding="0,10,0,10"
                BorderThickness="0,0,0,0"
                DockPanel.Dock="Bottom"
                Style="{StaticResource Style_Border_Color}">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical">
                    <TextBlock
                        Style="{StaticResource Style_Version}"
                        Text="Verfasser: RiAG Dr. Blankenburg"
                        TextWrapping="WrapWithOverflow" />
                    <TextBlock
                        Style="{StaticResource Style_Version}"
                        Text="{Binding Version, FallbackValue=Version}"
                        TextWrapping="WrapWithOverflow" />
                    <Button
                        x:Name="Test"
                        Content="Test"
                        Style="{StaticResource Button_Master}"
                        Visibility="Collapsed" />
                    <Button
                        x:Name="UserSwitch"
                        Width="150"
                        Height="30"
                        Click="UserSwitch_Click"
                        Content="Nutzerwechseln"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <!--  MainMenu  -->
            <Grid x:Name="MainMenu" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!--  Navigationsmenu  -->
                <Border Grid.Row="0" Style="{StaticResource Style_Border_Mainmenu}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button
                            x:Name="btn_Main"
                            Grid.Row="0"
                            Click="OpenPageOnMain"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="Visible">
                            <Button.Content>
                                <TextBlock Text="Hauptmenü" TextWrapping="WrapWithOverflow" />
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="btn_Sitzungsunterlagen"
                            Grid.Row="1"
                            Click="OpenPageOnMain"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="{Binding ShowSitzungsunterlagen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <Button.Content>
                                <TextBlock Text="{Binding SenatsText, UpdateSourceTrigger=PropertyChanged}" TextWrapping="WrapWithOverflow" />
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="btn_Sitzungplaene"
                            Grid.Row="2"
                            Click="OpenPageOnMain"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="{Binding ShowSitzungsplaene, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <Button.Content>
                                <TextBlock Text="Sitzungsdienste" TextWrapping="WrapWithOverflow" />
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="btn_Spruchgruppen"
                            Grid.Row="3"
                            Click="OpenPageOnMain"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="{Binding ShowSpruchgruppen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <Button.Content>
                                <TextBlock Text="Spruchgruppen" TextWrapping="WrapWithOverflow" />
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="btn_Montagspost"
                            Grid.Row="4"
                            Click="OpenPageOnMain"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="{Binding ShowMontagspost, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <Button.Content>
                                <TextBlock Text="Montagspost" TextWrapping="WrapWithOverflow" />
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="btn_MontagspostAdmin"
                            Grid.Row="5"
                            Click="OpenPageOnMain"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="{Binding ShowMontagspostAdmin, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <Button.Content>
                                <TextBlock Text="Montagspost-Admin" TextWrapping="WrapWithOverflow" />
                            </Button.Content>
                        </Button>
                        <Button
                            x:Name="btn_Nebentätigkeiten"
                            Grid.Row="6"
                            Click="OpenPageOnMain"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="{Binding ShowNebentaetigkeiten, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <Button.Content>
                                <TextBlock Text="Nebentätigkeiten" TextWrapping="WrapWithOverflow" />
                            </Button.Content>
                        </Button>
                    </Grid>
                </Border>
                <!--  Systemmenu  -->
                <Border Grid.Row="1" Style="{StaticResource Style_Border_Mainmenu}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button
                            x:Name="btn_Settings"
                            Grid.Row="0"
                            Click="OpenPageOnMain"
                            Content="Einstellungen"
                            Style="{StaticResource Style_Button_Menu}" />
                        <Button
                            x:Name="btn_Instruction"
                            Grid.Row="1"
                            Click="OpenPageOnMain"
                            Content="Anleitungen"
                            Style="{StaticResource Style_Button_Menu}" />
                        <Button
                            x:Name="btn_Test"
                            Grid.Row="2"
                            Click="OpenPageOnMain"
                            Content="TestInfoWindow"
                            Style="{StaticResource Style_Button_Menu}"
                            Visibility="Collapsed" />
                    </Grid>
                </Border>
                <!--  Statusbar  -->
                <Border
                    Grid.Row="2"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource Style_Border_Mainmenu}"
                    Visibility="{Binding ShowStatusBar, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Style="{StaticResource Style_MainWindow_Statusbar}" Text="Laufende Vorgänge:" />
                        <ListBox Margin="30,10,0,0" ItemsSource="{Binding ActionList, UpdateSourceTrigger=PropertyChanged}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="White"
                                            Style="{StaticResource textblock_base}">
                                            <Run Text="•" />
                                            <Run Text="{Binding ActionsStatusName, Mode=OneWay}" />
                                        </TextBlock>
                                        <Canvas
                                            Width="10"
                                            Height="10"
                                            Margin="10,0,0,0">
                                            <Rectangle
                                                x:Name="rect1"
                                                Width="8"
                                                Height="8"
                                                Fill="White"
                                                RenderTransformOrigin="0.5, 0.5">
                                                <Rectangle.RenderTransform>
                                                    <!--  giving the transform a name tells the framework not to freeze it  -->
                                                    <RotateTransform x:Name="noFreeze" />
                                                </Rectangle.RenderTransform>
                                                <Rectangle.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    RepeatBehavior="Forever"
                                                                    Storyboard.TargetProperty="(Rectangle.RenderTransform).(RotateTransform.Angle)"
                                                                    To="-360"
                                                                    Duration="0:0:1" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Rectangle.Triggers>
                                            </Rectangle>
                                        </Canvas>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <!--  Platzhalter für die Unterseiten  -->
        <Grid
            x:Name="PagePlace"
            Background="{StaticResource MaterialDesignPaper}"
            Column="1">
            <Border Grid.Column="1" BorderThickness="0,1,0,0">
                <Ctrl:AnimatedContentControl x:Name="AnimatedContentControl" />
            </Border>
        </Grid>
    </Grid>
</MW:MetroWindow>
