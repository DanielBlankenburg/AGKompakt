<Window
    x:Class="BGH_Kompakt.Views.Windows.ActivityRequestChangeListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Änderungshistorie"
    Width="850"
    Height="450"
    Language="de-DE"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <ListView
                x:Name="ListChanges"
                Margin="20,10,0,0"
                SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Width="500"
                            DisplayMemberBinding="{Binding ActivityRequestChangeHistoryText, TargetNullValue=[keine Angabe], UpdateSourceTrigger=PropertyChanged}"
                            Header="Änderung"
                            HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                        <GridViewColumn
                            Width="80"
                            DisplayMemberBinding="{Binding ActivityRequestChangeHistoryDate, TargetNullValue=[keine Angabe], UpdateSourceTrigger=PropertyChanged, StringFormat=d}"
                            Header="Datum"
                            HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                        <GridViewColumn
                            Width="200"
                            DisplayMemberBinding="{Binding ActivityRequestChangeHistoryAuthor, TargetNullValue=[keine Angabe], UpdateSourceTrigger=PropertyChanged}"
                            Header="Ändernde Person"
                            HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                    </GridView>
                </ListView.View>
            </ListView>

        </Grid>
        <Button
            x:Name="Btn_close"
            Grid.Row="1"
            Margin="0,0,15,0"
            HorizontalAlignment="Right"
            Click="Btn_close_Click"
            Content="Schließen"
            Style="{StaticResource Button_Master}" />
    </Grid>
</Window>
