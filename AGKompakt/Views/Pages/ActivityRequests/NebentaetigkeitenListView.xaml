    d:DesignHeight="900"
    d:DesignWidth="1400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style
                x:Key="Button_GridView"
                BasedOn="{StaticResource MaterialDesignRaisedButton}"
                TargetType="Button">
                <Setter Property="Background" Value="White" />
                <Setter Property="Width" Value="35" />
                <Setter Property="Margin" Value="0,0,10,0" />
                <Setter Property="Height" Value="22" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>
            <Style
                x:Key="Combobox_ARList"
                BasedOn="{StaticResource Combobox_Base}"
                TargetType="{x:Type ComboBox}">
                <Setter Property="Margin" Value="15,0" />
                <Setter Property="Width" Value="170" />
            </Style>
            <Style
                x:Key="TextboxMenu"
                BasedOn="{StaticResource textblock_base}"
                TargetType="{x:Type TextBlock}">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.ColumnSpan" Value="2" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="0,0,0,20" />
            </Style>
            <Style x:Key="GridMenu" TargetType="Grid">
                <Setter Property="Margin" Value="0,10,15,20" />
            </Style>
            <Style x:Key="ARListCard" TargetType="{x:Type MD:Card}">
                <Setter Property="Margin" Value="8" />
            </Style>
            <Style x:Key="ItemHeaderIcon" TargetType="MD:PackIcon">
                <Setter Property="Width" Value="25" />
                <Setter Property="Height" Value="25" />
                <Setter Property="Foreground" Value="DarkSlateGray" />
            </Style>
            <Style x:Key="ItemArrowUp" TargetType="MD:PackIcon">
                <Setter Property="Margin" Value="0,0,10,0" />
                <Setter Property="Kind" Value="ArrowUpward" />
            </Style>
            <Style x:Key="ItemArrowDown" TargetType="MD:PackIcon">
                <Setter Property="Margin" Value="0,0,10,0" />
                <Setter Property="Kind" Value="ArrowDownward" />
            </Style>
            <Style x:Key="PackIcon_AR" TargetType="MD:PackIcon">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>


        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{StaticResource BGHActivityRequestBackground}">
