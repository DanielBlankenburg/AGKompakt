                        <MenuItem.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,15,0"
                                    Content="Meldeart:" />
                                <ComboBox
                                    Grid.Column="1"
                                    DisplayMemberPath="Item"
                                    ItemsSource="{Binding FilterMeldeartList}"
                                    SelectedItem="{Binding FilterMeldeartSelected}" />
                            </Grid>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem>
                        <MenuItem.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,15,0"
                                    Content="Tätigkeitsart:" />
                                <ComboBox
                                    Grid.Column="1"
                                    DisplayMemberPath="Item"
                                    ItemsSource="{Binding FilterTaetigkeitsartList}"
                                    SelectedItem="{Binding FilterTaetigkeitsartSelected}" />
                            </Grid>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem>
                        <MenuItem.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,15,0"
                                    Content="Status:" />
                                <ComboBox
                                    Grid.Column="1"
                                    DisplayMemberPath="Item"
                                    ItemsSource="{Binding FilterStatusList}"
                                    SelectedItem="{Binding FilterStatusSelected}" />
                            </Grid>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Margin="0,10,0,0">
                        <MenuItem.Header>
                            <Button
                                Command="{Binding ReSetFilterCommand}"
                                Content="Filter zurücksetzen"
                                Style="{StaticResource Button_Master}" />
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </StackPanel>
        <ListView
            x:Name="listView"
            Grid.Row="1"
            Height="{Binding RelativeSource={RelativeSource AncestorType={x:Type Grid}}, Path=ActualHeight}"
            MaxHeight="550"
            Margin="0,30,0,0"
            ItemsSource="{Binding ActivityRequestsView, UpdateSourceTrigger=PropertyChanged}"
            ScrollViewer.HorizontalScrollBarVisibility="Visible"
            ScrollViewer.VerticalScrollBarVisibility="Visible"
            SelectedItem="{Binding SelectedActivityRequest, UpdateSourceTrigger=PropertyChanged}"
            SelectionMode="Single">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:InvokeCommandAction Command="{Binding EditCommand}" CommandParameter="{Binding ElementName=listView, Path=SelectedItem}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <ListView.View>
                <GridView>
                    <!--<GridViewColumn
                        Width="20"
                        DisplayMemberBinding="{Binding Changed}"
                        Header="" />-->
                    <GridViewColumn
                        Width="{Binding Path=DataContext.WidthUser, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, UpdateSourceTrigger=PropertyChanged}"
                        DisplayMemberBinding="{Binding ARUser.Fullname, TargetNullValue=[keine Angabe]}"
                        Header="Antragsteller"
                        HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                    <GridViewColumn
                        Width="130"
                        DisplayMemberBinding="{Binding ARTitel, TargetNullValue=[keine Angabe]}"
                        Header="Titel"
                        HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                    <GridViewColumn
                        Width="150"
                        DisplayMemberBinding="{Binding ActivityClient.ACName, TargetNullValue=[keine Angabe]}"
                        Header="Veranstalter"
                        HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                    <GridViewColumn Width="180" HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ActivityRequestMeldeArt.ActivityRequestMeldeArtText, TargetNullValue=[keine Angabe]}" />
                                        <TextBlock Text="{Binding ActivityRequestTyp.ActivityRequestTypText, TargetNullValue=[keine Angabe]}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        <GridViewColumnHeader>
                            <StackPanel>
                                <TextBlock Text="Meldeart" />
                                <TextBlock Text="Tätigkeitsart" />
                            </StackPanel>
                        </GridViewColumnHeader>
                    </GridViewColumn>
                    <GridViewColumn Width="130" HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ARDatum, TargetNullValue=[keine Angabe], StringFormat=d, ConverterCulture=de-DE}" />
                                        <TextBlock Text="{Binding ARActivityDate, TargetNullValue=[keine Angabe], StringFormat=d, ConverterCulture=de-DE}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        <GridViewColumnHeader>
                            <StackPanel>
                                <TextBlock Text="Eintragungsdatum" />
                                <TextBlock Text="Tätigkeitsdatum" />
                            </StackPanel>
                        </GridViewColumnHeader>
                    </GridViewColumn>
                    <GridViewColumn
                        Width="130"
                        DisplayMemberBinding="{Binding ARVerguetung, TargetNullValue=[keine Angabe], StringFormat={}{0:c}, ConverterCulture=de-DE}"
                        Header="Vergütung"
                        HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                    <!--<GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding AdventagesCount, TargetNullValue=[keine Angabe], ConverterCulture=de-DE}"
                        Header="Vorteile"
                        HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />-->
                    <GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding Gesamtzeitaufwand, TargetNullValue=[keine Angabe], ConverterCulture=de-DE}"
                        Header="Aufwand"
                        HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                    <GridViewColumn
                        Width="150"
                        DisplayMemberBinding="{Binding Status, TargetNullValue=[keine Angabe], ConverterCulture=de-DE}"
                        Header="Status"
                        HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                    <GridViewColumn Width="Auto">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                    <MD:PackIcon
                                        x:Name="PI_Check"
                                        Foreground="Green"
                                        Kind="Check"
                                        Style="{StaticResource PackIcon_AR}" />
                                    <MD:PackIcon
                                        x:Name="PI_Exclamation"
                                        Foreground="Black"
                                        Kind="Exclamation"
                                        Style="{StaticResource PackIcon_AR}" />
                                    <MD:PackIcon
                                        x:Name="PI_Reject"
                                        Foreground="Red"
                                        Kind="Close"
                                        Style="{StaticResource PackIcon_AR}" />
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ARCheck}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowSign, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="PI_Check" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ARExclamation}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowSign, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="PI_Exclamation" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ARRejected}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowSign, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="PI_Reject" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ARCheck}" Value="true" />
                                            <Condition Binding="{Binding ARZustaendigkeitsbereich}" Value="5" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="PI_Check" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ARRejected}" Value="true" />
                                            <Condition Binding="{Binding ARZustaendigkeitsbereich}" Value="5" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="PI_Reject" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>



                                    <!--<DataTrigger Binding="{Binding ARCheck}" Value="true">
                                        <Setter TargetName="PI_Check" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ARExclamation}" Value="true">
                                        <Setter TargetName="PI_Exclamation" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ARRejected}" Value="true">
                                        <Setter TargetName="PI_Reject" Property="Visibility" Value="Visible" />
                                    </DataTrigger>-->


                                    <!--<MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowEdit, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="Btn_Check" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="Btn_Exclamation" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="Btn_Reject" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>-->
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="250">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                    <Button
                                        x:Name="Btn_Edit"
                                        Command="{Binding Path=DataContext.EditCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                        Style="{StaticResource Button_GridView}"
                                        ToolTip="Anzeige/Antrag-Details anzeigen">
                                        <MD:PackIcon Padding="0" Kind="TextSearchVariant" />
                                    </Button>
                                    <Button
                                        x:Name="Btn_Bin"
                                        Command="{Binding Path=DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                        Style="{StaticResource Button_GridView}"
                                        ToolTip="Anzeige/Antrag löschen">
                                        <MD:PackIcon Padding="0" Kind="Bin" />
                                    </Button>
                                    <Button
                                        x:Name="Btn_Duplicate"
                                        Command="{Binding Path=DataContext.DuplicateCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                        Style="{StaticResource Button_GridView}"
                                        ToolTip="Kopie als neue/n Anzeige/Antrag anlegen">
                                        <MD:PackIcon Padding="0" Kind="ContentDuplicate" />
                                    </Button>
                                    <!--<Button
                                        x:Name="Btn_Reject"
                                        Command="{Binding Path=DataContext.RejectCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource Button_GridView}"
                                        ToolTip="Antrag ablehnen">
                                        <MD:PackIcon Padding="0" Kind="CloseOctagon" />
                                    </Button>-->
                                    <Button
                                        x:Name="Btn_Send"
                                        Command="{Binding Path=DataContext.SendCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource Button_GridView}"
                                        ToolTip="{Binding Path=DataContext.ToolTipSend, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, UpdateSourceTrigger=PropertyChanged}">
                                        <MD:PackIcon Padding="0" Kind="EmailAdd" />
                                    </Button>
                                    <!--<Button
                                        x:Name="Btn_Word"
                                        Command="{Binding Path=DataContext.WordCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource Button_GridView}"
                                        ToolTip="{Binding Path=DataContext.ToolTipSend, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, UpdateSourceTrigger=PropertyChanged}">
                                        <MD:PackIcon Padding="0" Kind="MicrosoftWord" />
                                    </Button>-->

                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true">
                                        <Setter TargetName="Btn_Edit" Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowSend, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="Btn_Send" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowDuplicate, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="Btn_Duplicate" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>

                                    <!--<MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowReject, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="Btn_Reject" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>-->
                                    <!--<MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowWord, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="Btn_Word" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>-->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true" />
                                            <Condition Binding="{Binding Path=DataContext.ShowBin, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Value="true" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="Btn_Bin" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>

                                    <!--<DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true">
                                        <Setter TargetName="Btn_Bin" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="Btn_Edit" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="Btn_Send" Property="Visibility" Value="Visible" />
                                    </DataTrigger>-->
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>

                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        <!--</MD:Card>-->
        <Button
            Grid.Row="4"
            Margin="30,20,0,10"
            HorizontalAlignment="Left"
            Command="{Binding NewRequestCommand}"
            Content="Neuer Antrag"
            Style="{StaticResource Button_Master}"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
