<UserControl
    x:Class="BGH_Kompakt.Views.Montagspost.MontagsPostVermerkView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Montagspost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montagspost="clr-namespace:BGH_Kompakt.ViewModel.Montagspost"
    d:DataContext="{d:DesignInstance Type=montagspost:MontagsPostVermerkViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Background="{StaticResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="Grid_Vermerk" TargetType="{x:Type Grid}">
            <Setter Property="Margin" Value="0,8" />
        </Style>
        <Style
            x:Key="Textarea_Vermerk"
            BasedOn="{StaticResource Textbox_Textarea}"
            TargetType="TextBox">
            <Setter Property="Padding" Value="10" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="20"
            FontWeight="Bold"
            Style="{StaticResource textblock_base}"
            Text="Verfahren" />
        <Grid Grid.Row="1" DataContext="{Binding SelectedDecision, UpdateSourceTrigger=PropertyChanged}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1">
                <Grid Style="{StaticResource Grid_Vermerk}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        Content="Aktenzeichen:"
                        Style="{StaticResource Label_Base}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource textblock_base}"
                        Text="{Binding Aktenzeichen}" />
                </Grid>
                <Grid Style="{StaticResource Grid_Vermerk}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Content="Sperrvermerk anzeigen:"
                        Style="{StaticResource Label_Base}" />
                    <MW:ToggleSwitch
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Left"
                        IsOn="{Binding VermerkAnzeige}"
                        OffContent=""
                        OnContent=""
                        Style="{StaticResource ToggleSwitchMaster}"
                        ToolTip="Anstatt der pdf-Vorschau wird ein Sperrvermerk angezeigt. Dort wird der Vermerktext eingesteuert." />
                </Grid>
                <Grid Style="{StaticResource Grid_Vermerk}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Content="E-Mail versenden:"
                        Style="{StaticResource Label_Base}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <MW:ToggleSwitch
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsOn="{Binding EMailVersenden}"
                            OffContent=""
                            OnContent=""
                            Style="{StaticResource ToggleSwitchMaster}"
                            ToolTip="An sämtliche angemeldete Nutzer wird eine E-Mail mit dem Vermerk versandt." />
                        <Button Command="{Binding Path=DataContext.EMailPreviewCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" Style="{StaticResource Button_Master}">
                            <StackPanel Orientation="Horizontal">
                                <MD:PackIcon Kind="EmailSearchOutline" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    Style="{StaticResource textblock_base}"
                                    Text="Vorschau" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
                <!--<Grid Style="{StaticResource Grid_Vermerk}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Content="Autotext:"
                        Style="{StaticResource Label_Base}" />
                    <ComboBox
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        MinWidth="150"
                        HorizontalAlignment="Left"
                        DisplayMemberPath="MPVermerkText"
                        IsEditable="True"
                        ItemsSource="{Binding Path=DataContext.VermerkList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                        SelectedItem="{Binding Path=DataContext.SelectedVermerk, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Delay=1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="An sämtliche angemeldete Nutzer wird eine E-Mail mit dem Vermerk versandt." />
                </Grid>-->
                <Grid Style="{StaticResource Grid_Vermerk}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        Content="Vermerk:"
                        Style="{StaticResource Label_Base}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox
                            Width="300"
                            Height="150"
                            Style="{StaticResource Textarea_Vermerk}"
                            Text="{Binding Path=DataContext.Vermerktext, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox
                            Height="150"
                            Padding="0,0,10,0"
                            HorizontalAlignment="Right"
                            BorderThickness="0,1,1,1"
                            DisplayMemberPath="MPVermerkText"
                            ItemsSource="{Binding Path=DataContext.VermerkList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                            SelectedItem="{Binding Path=DataContext.SelectedVermerk, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Delay=1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            ToolTip="An sämtliche angemeldete Nutzer wird eine E-Mail mit dem Vermerk versandt." />
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Grid>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,10,0"
                Command="{Binding SaveCommand}"
                Content="Vermerk speichern"
                Style="{StaticResource Button_Master}" />
            <Button
                Margin="0,0,20,0"
                Command="{Binding BackCommand}"
                Content="Zurück ohne Speichern"
                Style="{StaticResource Button_Master}" />
        </StackPanel>

    </Grid>
</UserControl>
