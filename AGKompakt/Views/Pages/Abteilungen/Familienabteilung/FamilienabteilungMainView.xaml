<UserControl
    x:Class="BGH_Kompakt.Views.Pages.Abteilungen.Familienabteilung.FamilienabteilungMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:familienabteilung="clr-namespace:BGH_Kompakt.ViewModel.Abteilungen.Familienabteilung"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.Abteilungen.Familienabteilung"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=familienabteilung:FamilienabteilungMainViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Button_Settings"
            BasedOn="{StaticResource Button_Mainwindow}"
            TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="40,30,0,0" />
        </Style>
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" />
        <WrapPanel Grid.Row="1">
            <Button Command="{Binding VerfahrensbeistandCommand}" Style="{StaticResource Button_Settings}">
                <StackPanel>
                    <Image
                        Source="/Resources/ImageResources/Images/List.jpg"
                        Stretch="Fill"
                        Style="{StaticResource Button_Mainwindow_Image}" />
                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Liste Verfahrensbeistände" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource Button_Settings}">
                <StackPanel>
                    <Image
                        Source="/Resources/ImageResources/Images/Montagspost.png"
                        Stretch="Fill"
                        Style="{StaticResource Button_Mainwindow_Image}" />
                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Unterlagen Familiengericht" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource Button_Settings}">
                <StackPanel>
                    <Image
                        Source="/Resources/ImageResources/Images/Montagspost.png"
                        Stretch="Fill"
                        Style="{StaticResource Button_Mainwindow_Image}" />
                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Urteilsdatenbank" />
                </StackPanel>
            </Button>

        </WrapPanel>
    </Grid>
</UserControl>
