<UserControl
    x:Class="BGH_Kompakt.Views.Pages.Abteilungen.Familienabteilung.VerfahrensbeistaendeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:familienabteilung="clr-namespace:BGH_Kompakt.ViewModel.Abteilungen.Familienabteilung"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.Abteilungen.Familienabteilung"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=familienabteilung:VerfahrensbeistaendeViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.ColumnSpan="2" Text="Verfahrensbeistände" />
        <!--<ListBox
            Grid.Row="1"
            Grid.Column="0"
            ItemsSource="{Binding VBList}"
            Style="{StaticResource MaterialDesignCardsListBox}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="40,0,0,10">
                        <TextBlock FontWeight="Bold" Text="{Binding VorName}" />
                        <TextBlock Text="{Binding NachName}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>-->
        <DataGrid
            Grid.Row="1"
            Grid.Column="0"
            Margin="5,5,5,5"
            HorizontalScrollBarVisibility="Disabled"
            ItemsSource="{Binding VBList, UpdateSourceTrigger=PropertyChanged}"
            SelectedItem="{Binding SelectedMPWeek, UpdateSourceTrigger=PropertyChanged}"
            SelectionMode="Single"
            VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="*" MinWidth="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,0,0,10">
                                <TextBlock FontWeight="Bold" Text="{Binding VorName}" />
                                <TextBlock Text="{Binding NachName}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridColumn.Header>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Verfahrensbeistand" />
                            <!--<Button
                                                    x:Name="Add_KW"
                                                    Width="50"
                                                    Height="25"
                                                    Margin="10,0,0,0"
                                                    components:FileDragDropHelper.FileDragDropTarget="{Binding}"
                                                    components:FileDragDropHelper.IsFileDragDropEnabled="True"
                                                    AllowDrop="True"
                                                    Background="White"
                                                    BorderThickness="0">
                                                    <MD:PackIcon Kind="Add" />
                                                </Button>-->
                        </StackPanel>
                    </DataGridColumn.Header>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>


    </Grid>
</UserControl>
