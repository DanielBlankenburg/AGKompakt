<UserControl
    x:Class="BGH_Kompakt.Views.Pages.Abteilungen.Familienabteilung.VerfahrensbeistaendeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:familienabteilung="clr-namespace:BGH_Kompakt.ViewModel.Abteilungen.Familienabteilung"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.Abteilungen.Familienabteilung"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=familienabteilung:VerfahrensbeistaendeViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.ColumnSpan="2"
            FontSize="22"
            FontWeight="Bold"
            Text="Verfahrensbeistände"
            TextAlignment="Center" />
        <DataGrid
            Grid.Row="1"
            Grid.Column="0"
            Margin="5,5,5,5"
            HorizontalScrollBarVisibility="Disabled"
            ItemsSource="{Binding VBList, UpdateSourceTrigger=PropertyChanged}"
            SelectedItem="{Binding SelectedVB, UpdateSourceTrigger=PropertyChanged}"
            SelectionMode="Single"
            VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="*" MinWidth="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,0,0,10">
                                <TextBlock FontWeight="Bold" Text="{Binding VorName}" />
                                <TextBlock Text="{Binding NachName}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="1" Grid.Column="1">
            <StackPanel Margin="10,0,0,10">
                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Text="{Binding SelectedVB.VorName}" />
                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Text="{Binding SelectedVB.NachName}" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
