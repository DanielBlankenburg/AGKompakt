<UserControl
    x:Class="BGH_Kompakt.Views.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Ctrl="clr-namespace:BGH_Kompakt.Components"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">
    <Grid Background="{StaticResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource Style_Textblock_Titel}" Text="Einstellungen" />
        <Border
            Grid.Row="1"
            Grid.Column="0"
            BorderThickness="0,1,0,0">
            <Ctrl:AnimatedContentControl x:Name="AnimatedContentControl" />
        </Border>
        <Grid
            x:Name="Grid_Settings"
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            Background="{StaticResource BGH-Color}">
            <Border
                Grid.Row="2"
                Grid.Column="2"
                Height="160"
                VerticalAlignment="Top"
                BorderThickness="0,0,0,1"
                Style="{StaticResource Style_Border_Color}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,5,0,0"
                        Background="{StaticResource BGH-Color}"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource Style_Textbox_Button}"
                        Text="ANZEIGE"
                        TextAlignment="Center" />
                    <StackPanel Grid.Row="1">
                        <Button
                            x:Name="Btn_Open_Senatseinstellungen"
                            Margin="0,0,0,10"
                            Click="Btn_Open_Senatseinstellungen_Click"
                            Style="{StaticResource Style_Button_Sitzungsunterlagen_Neu}">
                            <StackPanel Orientation="Horizontal">
                                <MD:PackIcon Height="40" Kind="Cog" />
                                <TextBlock
                                    Width="140"
                                    Height="Auto"
                                    Margin="10,10,0,0"
                                    HorizontalAlignment="Center"
                                    Text="Senatseinstellungen"
                                    TextAlignment="left"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="Btn_Open_UserVerwaltung"
                            Margin="0,0,0,10"
                            Click="Btn_Open_UserVerwaltung_Click"
                            Style="{StaticResource Style_Button_Sitzungsunterlagen_Neu}">
                            <StackPanel Orientation="Horizontal">
                                <MD:PackIcon Height="40" Kind="Account" />
                                <TextBlock
                                    Width="140"
                                    Height="Auto"
                                    Margin="10,10,0,0"
                                    HorizontalAlignment="Center"
                                    Text="User-Verwaltung"
                                    TextAlignment="left"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
