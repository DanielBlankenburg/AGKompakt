<UserControl
    x:Class="BGH_Kompakt.Views.Settings.MPSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:systemsettings="clr-namespace:BGH_Kompakt.ViewModel.SystemSettings"
    d:DataContext="{d:DesignInstance Type=systemsettings:MPSettingsViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Button_ProgrammSettings"
            BasedOn="{StaticResource Button_Master}"
            TargetType="{x:Type Button}">
            <Setter Property="MaxWidth" Value="150" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,15,0,15" />
        </Style>
        <Style
            x:Key="MPSettingTextbox"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
        <Style
            x:Key="MPSettingTitel"
            BasedOn="{StaticResource Style_Textblock_Titel_Unter2}"
            TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
        <Style x:Key="MDCard_MPSettings" TargetType="{x:Type MD:Card}">
            <Setter Property="Margin" Value="20,10" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="ToggleSwitchSetting" TargetType="{x:Type MW:ToggleSwitch}">
            <Setter Property="OffContent" Value="Aus" />
            <Setter Property="OnContent" Value="An" />
            <!--<Setter Property="Margin" Value="0,0,10,0" />-->
        </Style>

        <!--<Style
            x:Key="Border_Programmsettings"
            BasedOn="{StaticResource Expander_Border}"
            TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="10,0" />
        </Style>
        <Style
            x:Key="Label_Programmsettings"
            BasedOn="{StaticResource Label_Base}"
            TargetType="{x:Type Label}">
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style
            x:Key="Textbox_Programmsettings"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="{x:Type TextBox}">
            <Setter Property="MinWidth" Value="300" />
            <Setter Property="MaxWidth" Value="400" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>-->
    </UserControl.Resources>
    <StackPanel Background="{StaticResource MaterialDesignPaper}">
        <MD:Card Style="{StaticResource MDCard_MPSettings}">
            <StackPanel VerticalAlignment="Top" Orientation="Vertical">
                <TextBlock Style="{StaticResource MPSettingTitel}" Text="Allgemeine E-Mail-Einstellungen" />
                <StackPanel DataContext="{Binding MPSetting}">
                    <TextBox
                        MD:HintAssist.Hint="Anrede:"
                        Style="{StaticResource MPSettingTextbox}"
                        Text="{Binding MPSettingEMailAnrede}" />
                    <TextBox
                        MD:HintAssist.Hint="Schlussformel:"
                        Style="{StaticResource MPSettingTextbox}"
                        Text="{Binding MPSettingEMailSchluss}" />
                    <TextBox
                        MD:HintAssist.Hint="Datenschutzhinweis:"
                        Style="{StaticResource MPSettingTextbox}"
                        Text="{Binding MPSettingDatenschutzhinweis}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <Button
                    Command="{Binding SaveEMailCommand}"
                    Content="Speichern"
                    Style="{StaticResource Button_ProgrammSettings}" />
            </StackPanel>
        </MD:Card>
        <MD:Card Style="{StaticResource MDCard_MPSettings}">
            <StackPanel>
                <TextBlock Style="{StaticResource MPSettingTitel}" Text="Autotexte Vermerke" />
                <ListView
                    ItemsSource="{Binding EMailList, Mode=OneWay}"
                    SelectedItem="{Binding SelectedEMail}"
                    SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn
                                Width="Auto"
                                DisplayMemberBinding="{Binding MPEMailDescription, TargetNullValue=[keine Angabe]}"
                                Header="Art"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                            <GridViewColumn
                                Width="Auto"
                                DisplayMemberBinding="{Binding MPEMailSubject, TargetNullValue=[keine Angabe]}"
                                Header="Betreff"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                            <!--<GridViewColumn
                                Width="Auto"
                                DisplayMemberBinding="{Binding MPEMailBody, TargetNullValue=[keine Angabe]}"
                                Header="Textkörper"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />-->
                            <GridViewColumn
                                Width="600"
                                Header="Textkörper"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            Margin="0"
                                            BorderThickness="0"
                                            Text="{Binding MPEMailBody, TargetNullValue=[keine Angabe]}"
                                            TextWrapping="WrapWithOverflow" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>


                        </GridView>
                    </ListView.View>
                </ListView>
                <Button
                    Command="{Binding SaveAutotextCommand}"
                    Content="Speichern"
                    Style="{StaticResource Button_ProgrammSettings}" />

            </StackPanel>
        </MD:Card>
        <MD:Card Style="{StaticResource MDCard_MPSettings}">
            <StackPanel>
                <StackPanel DataContext="{Binding MPSetting}">

                    <TextBlock Style="{StaticResource MPSettingTitel}" Text="BSCW-Server-Einstellungen" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label
                            Grid.Column="0"
                            Content="Upload BSCW-Server"
                            Style="{StaticResource Style_label_PersonChange}" />
                        <MW:ToggleSwitch
                            Grid.Column="1"
                            IsOn="{Binding UploadBSCWServer, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource ToggleSwitchSetting}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Style="{StaticResource Style_label_PersonChange}">
                            Buchstabe Laufwerk BSCW-Server
                        </Label>
                        <ComboBox
                            Grid.Row="1"
                            Grid.Column="2"
                            MaxWidth="100"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Center"
                            ItemsSource="{Binding Path=DataContext.DriveList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                            SelectedItem="{Binding BSCWServerDrive}" />
                    </Grid>
                </StackPanel>
                <Button
                    Command="{Binding SaveBSCWServerCommand}"
                    Content="Speichern"
                    Style="{StaticResource Button_ProgrammSettings}" />


            </StackPanel>

        </MD:Card>
    </StackPanel>

</UserControl>
