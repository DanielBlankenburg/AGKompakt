<UserControl
    x:Class="BGH_Kompakt.Views.Start.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:start="clr-namespace:BGH_Kompakt.ViewModel.Start"
    d:DataContext="{d:DesignInstance Type=start:StartViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="ButtonMainwindow"
            BasedOn="{StaticResource MahApps.Styles.Button}"
            TargetType="{x:Type Button}">
            <Setter Property="Width" Value="300" />
            <Setter Property="Height" Value="280" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0,10,0,20" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <!--<Setter Property="Height" Value="250" />-->
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Height"
                                    To="350"
                                    Duration="0:0:0.300" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Height"
                                    To="280"
                                    Duration="0:0:0.300" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ButtonMainwindowButtonBorder" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Height" Value="380" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Margin" Value="5,0" />
        </Style>
        <Style x:Key="ButtonMainwindowImageBorder" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Height" Value="200" />
            <Setter Property="Width" Value="250" />
        </Style>
        <Style
            x:Key="ButtonMainwindowInformationBorder"
            BasedOn="{StaticResource MahApps.Styles.Button.Circle}"
            TargetType="{x:Type Button}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>
    <Grid
        x:Name="PagePlace"
        Grid.ColumnSpan="2"
        Background="{StaticResource MaterialDesignPaper}"
        Column="1">

        <Grid>
            <Grid.RowDefinitions>
                <!--<RowDefinition Height="60" />-->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0"
                Style="{StaticResource Style_Textblock_Titel}"
                Text="{Binding Title}" />
            <MD:Card
                Grid.Row="1"
                Grid.Column="0"
                Margin="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel
                        Grid.Row="0"
                        MinWidth="700"
                        Margin="30,30,0,20">
                        <!--#region Sitzungsunterlagen-->
                        <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                            <Button
                                x:Name="BtnMainSitzungsunterlagen"
                                Click="OpenPageOnMain"
                                Style="{StaticResource ButtonMainwindow}"
                                Visibility="{Binding ShowSitzungsunterlagen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <StackPanel VerticalAlignment="Top">
                                    <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="/Resources/ImageResources/Images/Unterlagen.jpg" Stretch="Fill" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="{Binding SenatsText}" />
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,5,40,0"
                                            FontSize="16"
                                            Style="{StaticResource textblock_base}"
                                            Text="{Binding Title}" />
                                        <Button
                                            x:Name="BtnInfoSitzungsunterlagen"
                                            Click="InfoClick"
                                            Style="{StaticResource ButtonMainwindowInformationBorder}">
                                            <MD:PackIcon
                                                Width="25"
                                                Height="25"
                                                Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                                Kind="InformationCircle" />
                                        </Button>
                                    </StackPanel>

                                </StackPanel>
                            </Button>
                        </Border>
                        <!--#endregion-->
                        <!--#region Spruchgruppen-->
                        <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                            <Button
                                x:Name="BtnMainSpruchgruppen"
                                Click="OpenPageOnMain"
                                Style="{StaticResource ButtonMainwindow}"
                                Visibility="{Binding ShowSpruchgruppen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <StackPanel VerticalAlignment="Top">
                                    <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="/Resources/ImageResources/Images/chairs-2181916_1280.jpg" Stretch="Fill" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Spruchgruppen" />
                                    <Button
                                        x:Name="BtnInfoSpruchgruppen"
                                        Click="InfoClick"
                                        Style="{StaticResource ButtonMainwindowInformationBorder}">
                                        <MD:PackIcon
                                            Width="25"
                                            Height="25"
                                            Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                            Kind="InformationCircle" />
                                    </Button>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!--#endregion-->
                        <!--#region Nebentätigkeiten-->
                        <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                            <Button
                                x:Name="BtnNebentaetigkeiten"
                                Click="OpenPageOnMain"
                                Style="{StaticResource ButtonMainwindow}"
                                Visibility="{Binding ShowNebentaetigkeiten, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <StackPanel VerticalAlignment="Top">
                                    <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="/Resources/ImageResources/Images/Nebentaetigkeiten-stift.jpg" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Nebentätigkeiten" />
                                    <Button
                                        x:Name="BtnInfoNebentaetigkeiten"
                                        Click="InfoClick"
                                        Style="{StaticResource ButtonMainwindowInformationBorder}">
                                        <MD:PackIcon
                                            Width="25"
                                            Height="25"
                                            Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                            Kind="InformationCircle" />
                                    </Button>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!--#endregion-->
                        <!--#region Sitzungspläne-->
                        <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                            <Button
                                x:Name="BtnMainSitzungsplaene"
                                Click="OpenPageOnMain"
                                Style="{StaticResource ButtonMainwindow}"
                                Visibility="{Binding ShowSitzungsplaene, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <StackPanel VerticalAlignment="Top">
                                    <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="/Resources/ImageResources/Images/holzhammer-und-buecher-auf-holztisch.png" Stretch="Fill" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Sitzungsdienste" />
                                    <Button
                                        x:Name="BtnInfoSitzungsplaene"
                                        Click="InfoClick"
                                        Style="{StaticResource ButtonMainwindowInformationBorder}">
                                        <MD:PackIcon
                                            Width="25"
                                            Height="25"
                                            Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                            Kind="InformationCircle" />
                                    </Button>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!--#endregion-->
                        <!--#region Montagspost-->
                        <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                            <Button
                                x:Name="BtnMainMontagspost"
                                Click="OpenPageOnMain"
                                Style="{StaticResource ButtonMainwindow}"
                                Visibility="{Binding ShowMontagspost, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <StackPanel VerticalAlignment="Top">
                                    <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="/Resources/ImageResources/Images/Montagspost.png" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Montagspost" />
                                    <Button
                                        x:Name="BtnInfoMontagspost"
                                        Click="InfoClick"
                                        Style="{StaticResource ButtonMainwindowInformationBorder}">
                                        <MD:PackIcon
                                            Width="25"
                                            Height="25"
                                            Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                            Kind="InformationCircle" />
                                    </Button>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!--#endregion-->
                        <!--#region Montagspost Admin-->
                        <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                            <Button
                                x:Name="BtnMontagspostAdmin"
                                Click="OpenPageOnMain"
                                Style="{StaticResource ButtonMainwindow}"
                                Visibility="{Binding ShowMontagspostAdmin, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <StackPanel VerticalAlignment="Top">
                                    <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="/Resources/ImageResources/Images/Montagspost-Admin.jpg" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Montagspost Admin" />
                                    <Button
                                        x:Name="BtnInfoMontagspostAdmin"
                                        Click="InfoClick"
                                        Style="{StaticResource ButtonMainwindowInformationBorder}">
                                        <MD:PackIcon
                                            Width="25"
                                            Height="25"
                                            Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                            Kind="InformationCircle" />
                                    </Button>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!--#endregion-->

                    </WrapPanel>
                </ScrollViewer>

            </MD:Card>
            <MD:Card
                Grid.Row="1"
                Grid.Column="1"
                Margin="10">

                <StackPanel
                    Grid.Row="0"
                    Margin="0,70,0,20"
                    HorizontalAlignment="Center"
                    Orientation="Vertical">

                    <Button
                        x:Name="Btn_Main_PersonChange"
                        Margin="0,0,0,20"
                        Click="OpenPageOnMain"
                        Style="{StaticResource Button_Mainwindow_Lower}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Image
                                Grid.Row="0"
                                Source="/Resources/ImageResources/Images/Einstellungen.png"
                                Stretch="Fill"
                                Style="{StaticResource Button_Mainwindow_Image}" />
                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource Button_Mainwindow_Textblock}"
                                Text="Einstellungen" />
                        </Grid>
                    </Button>

                    <Button
                        x:Name="Btn_Main_Instruction"
                        Click="OpenPageOnMain"
                        Style="{StaticResource Button_Mainwindow_Lower}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Image
                                Grid.Row="0"
                                Source="/Resources/ImageResources/Images/Anleitung.png"
                                Stretch="Fill"
                                Style="{StaticResource Button_Mainwindow_Image}" />
                            <TextBlock
                                Grid.Row="1"
                                Style="{StaticResource Button_Mainwindow_Textblock}"
                                Text="Anleitungen" />
                        </Grid>
                    </Button>
                    <!--<Button
                    x:Name="TestDesign"
                    Click="TestDesign_Click"
                    Content="TestDesing" />-->
                </StackPanel>
            </MD:Card>
        </Grid>



    </Grid>
</UserControl>
