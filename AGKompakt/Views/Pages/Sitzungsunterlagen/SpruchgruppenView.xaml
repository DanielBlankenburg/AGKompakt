<UserControl
    x:Class="BGH_Kompakt.Views.SpruchgruppenView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Background="{StaticResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Margin="0,10,0,0"
            FontFamily="{StaticResource MaterialDesignFont}"
            FontSize="30"
            FontWeight="Bold"
            Text="Spruchgruppen IX. Zivilsenat"
            TextAlignment="Center" />
        <Grid Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="160" />
                <RowDefinition Height="400" />
            </Grid.RowDefinitions>
            <MD:Card
                Grid.Row="0"
                Width="760"
                Margin="0,0,0,10"
                HorizontalAlignment="Center">
                <Grid Margin="20,0,0,0" Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource Style_Textblock_Spruchgruppen}"
                        Text="Aktenzeichen:" />
                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal">
                        <TextBlock
                            FontWeight="Bold"
                            Style="{StaticResource Style_Textblock_Spruchgruppen}"
                            Text="IX" />
                        <StackPanel Margin="15,10,0,0">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Style="{StaticResource Style_Textblock_Spruchgruppen}"
                                Text="ZR" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Style="{StaticResource Style_Textblock_Spruchgruppen}"
                                Text="ZB" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Style="{StaticResource Style_Textblock_Spruchgruppen}"
                                Text="ZA" />
                        </StackPanel>
                        <TextBox
                            x:Name="Txt_LaufendeNummer"
                            Style="{StaticResource Style_Textbox_Spruchgruppen}"
                            TextChanged="Txt_LaufendeNummer_TextChanged" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource Style_Textblock_Spruchgruppen}"
                            Text="/" />
                        <TextBox Style="{StaticResource Style_Textbox_Spruchgruppen}" />
                    </StackPanel>
                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="2"
                        Orientation="Horizontal">
                        <CheckBox />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource Style_Textblock_Spruchgruppen}"
                            Text="Vergütungssache nach InsVV" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource Style_Textblock_Spruchgruppen}"
                        Text="Zeitraum:" />
                    <ComboBox
                        x:Name="Cbo_Zeitraum"
                        Grid.Row="1"
                        Grid.Column="1"
                        Width="200"
                        Margin="15,0,0,0"
                        HorizontalAlignment="Left"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="16" />
                </Grid>
            </MD:Card>
            <Grid
                Height="350"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>
                <MD:Card x:Name="Grid_Aktuelle_Spruchgruppe" Grid.Column="0">
                    <StackPanel
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Vertical">
                        <StackPanel
                            Grid.Column="0"
                            Margin="20,0,0,0"
                            Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Style_Textblock_Spruchgruppen}" Text="Spruchgruppe:" />
                            <TextBox
                                x:Name="txt_Spruchgruppe"
                                IsEnabled="false"
                                Style="{StaticResource Style_Textbox_Spruchgruppen}" />
                        </StackPanel>
                        <DataGrid
                            x:Name="Data_Spruchgruppe"
                            Margin="15"
                            HorizontalScrollBarVisibility="Hidden">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Width="50"
                                                    Text="{Binding Dienstbezeichnung}"
                                                    TextAlignment="Left" />
                                                <TextBlock
                                                    Margin="10,0,0,0"
                                                    Text="{Binding Name_Voll}"
                                                    TextAlignment="Left" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </MD:Card>
                <Button
                    x:Name="Btn_NeueSpruchgruppe"
                    Grid.Column="1"
                    Height="70"
                    Margin="15">
                    <TextBlock
                        Text="Neue Spruchgruppe bestimmen"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </Button>
                <MD:Card x:Name="Grid_Spruchgruppe_Neu" Grid.Column="2">
                    <StackPanel
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Vertical">
                        <StackPanel
                            Grid.Column="0"
                            Margin="20,0,0,0"
                            Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Style_Textblock_Spruchgruppen}" Text="Neue Spruchgruppe:" />
                            <TextBox IsEnabled="false" Style="{StaticResource Style_Textbox_Spruchgruppen}" />
                        </StackPanel>
                        <DataGrid x:Name="Data_Spruchgruppe_Neu" Margin="15" />
                    </StackPanel>
                </MD:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
