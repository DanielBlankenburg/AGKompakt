<UserControl
    x:Class="BGH_Kompakt.Views.Sitzungsunterlagen.SitzungsunterlagenView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Classes="clr-namespace:BGH_Kompakt.Classes"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:components="clr-namespace:BGH_Kompakt.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Sitzungsunterlagen"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sitzungsunterlagen="clr-namespace:BGH_Kompakt.ViewModel.Sitzungsunterlagen"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:webbrowser="clr-namespace:BGH_Kompakt.AttchedProperties"
    d:DataContext="{d:DesignInstance Type=sitzungsunterlagen:SitzungsunterlagenViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Language="de-DE"
    mc:Ignorable="d">
    <!--  resources  -->
    <UserControl.Resources>
        <sys:Double x:Key="BaseFont_Sitzungsunterlagen">16</sys:Double>
        <sys:Double x:Key="HeaderFont_Sitzungsunterlagen">20</sys:Double>
        <sys:Double x:Key="PackIcon_Height">40</sys:Double>
        <Style x:Key="Gridsplitter_Sitzungsunterlagen" TargetType="{x:Type GridSplitter}">
            <Setter Property="Height" Value="150" />
            <Setter Property="Width" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Gray" />
            <Setter Property="ShowsPreview" Value="True" />
        </Style>
        <Style
            x:Key="Menu_Headline"
            BasedOn="{StaticResource Style_Textbox_Button}"
            TargetType="TextBlock">
            <Setter Property="Background" Value="{StaticResource BGH-Color}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style
            x:Key="Button_Sitzungstage"
            BasedOn="{StaticResource MaterialDesignRaisedButton}"
            TargetType="{x:Type Button}">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style
            x:Key="Button_Sitzungstage_MarginRigh"
            BasedOn="{StaticResource Button_Sitzungstage}"
            TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="10,0,10,0" />
        </Style>


        <Style x:Key="Button_Verfahren_Border" TargetType="Border">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="DockPanel.Dock" Value="Left" />
        </Style>
        <Style x:Key="Button_Verfahren_Stackpanel" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>
        <Style
            x:Key="Button_Verfahren_Button"
            BasedOn="{StaticResource Style_Button_Listen}"
            TargetType="Button">
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <!--<Setter Property="IsEnabled" Value="false" />-->
        </Style>
        <Style x:Key="Button_Verfahren_PackIcon" TargetType="MD:PackIcon">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="IsEnabled" Value="false" />
        </Style>
        <Style x:Key="Button_List_Add_PackIcon" TargetType="MD:PackIcon">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        <Style x:Key="Button_Verfahren_Label" TargetType="Label">
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource MaterialDesignFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="DockPanel.Dock" Value="Left" />
        </Style>
        <Style
            x:Key="Button_Sitzungsunterlagen_Menu"
            BasedOn="{StaticResource MaterialDesignFlatButton}"
            TargetType="Button">
            <Setter Property="Width" Value="35" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="5,0,0,5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
        <Style
            x:Key="Button_Sitzungsunterlagen_Menu_Margin"
            BasedOn="{StaticResource Button_Sitzungsunterlagen_Menu}"
            TargetType="Button">
            <Setter Property="Margin" Value="5,2,0,5" />
        </Style>
        <Style x:Key="Button_Sitzungsunterlagen_Menu_PackIcon" TargetType="MD:PackIcon">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style x:Key="Datagrid_Sitzungsunterlagen_Textblock_Row" TargetType="TextBlock">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Margin" Value="0,3,20,0" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>
        <Style
            x:Key="Datagrid_Sitzungsunterlagen"
            BasedOn="{StaticResource DataGrid_Tite}"
            TargetType="DataGrid">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Margin" Value="0,10,5,5" />
            <Setter Property="Padding" Value="10,0,10,10" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="SelectionMode" Value="Single" />
        </Style>
        <Style
            x:Key="Style_Textblock_Eingabe_Header"
            BasedOn="{StaticResource MaterialDesignTextBlock}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{DynamicResource HeaderFont_Sitzungsunterlagen}" />
            <Setter Property="Margin" Value="0,10,0,10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontFamily" Value="{StaticResource MaterialDesignFont}" />
        </Style>
        <Style
            x:Key="Style_Textblock_Eingabe_Text"
            BasedOn="{StaticResource MaterialDesignTextBlock}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,10,20" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
            <Setter Property="FontFamily" Value="{StaticResource MaterialDesignFont}" />
        </Style>
        <Style x:Key="DataGrid_Header_Stackpanel" TargetType="{x:Type StackPanel}">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="10,10,10,10" />
        </Style>
        <Style x:Key="DataGrid_Header_Wrappanel" TargetType="{x:Type WrapPanel}">
            <Setter Property="Margin" Value="10,10,10,10" />
        </Style>

        <Style x:Key="DataGrid_Header_Textblock" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource MaterialDesignFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style
            x:Key="Textbox_Sitzungsunterlagen"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Width" Value="400" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style x:Key="Textblock_Radiobutton" TargetType="TextBlock">
            <Setter Property="Margin" Value="5,0,0,0" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style
            x:Key="Textblock_Radiobutton_Menu"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,5" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style x:Key="Label_BE" TargetType="{x:Type Label}">
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style
            x:Key="Combobox_BE"
            BasedOn="{StaticResource Combobox_Base}"
            TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="0,0,25,0" />
            <Setter Property="MinWidth" Value="150" />
        </Style>
        <Style
            x:Key="Combobox_Add"
            BasedOn="{StaticResource Combobox_Base}"
            TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="10,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="TextBlock.HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Card_List" TargetType="{x:Type MD:Card}">
            <Setter Property="Margin" Value="5,5,5,10" />
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="Width" Value="145" />
        </Style>


    </UserControl.Resources>

    <Grid Background="{StaticResource MaterialDesignPaper}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" IsEnabled="{Binding ShowEnableCards, UpdateSourceTrigger=PropertyChanged}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="6*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10*" />
            </Grid.ColumnDefinitions>
            <!--  Head  -->
            <TextBlock
                Grid.Column="0"
                Grid.ColumnSpan="5"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource MaterialDesignFont}"
                FontSize="{DynamicResource HeaderFont_Sitzungsunterlagen}"
                FontWeight="ExtraBlack"
                Text="{Binding Title}" />
            <Border
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="3,14,3,16"
                BorderThickness="0,0,0,1"
                Style="{StaticResource Style_Border_Color}">
                <!--<MD:Card
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"

                    Margin="5,0,0,10"
                    HorizontalAlignment="Left">-->
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="30,0,0,0"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,10,20,0"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="{DynamicResource BaseFont_Sitzungsunterlagen}"
                        FontWeight="Medium"
                        Text="Bitte wählen Sie einen Jahrgang aus:"
                        TextAlignment="Center" />
                    <ComboBox
                        Width="100"
                        Margin="0,0,10,0"
                        HorizontalContentAlignment="Center"
                        DisplayMemberPath="Jahr"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="{DynamicResource BaseFont_Sitzungsunterlagen}"
                        ItemsSource="{Binding VintageList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedItem="{Binding SelectedVintage, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <!--</MD:Card>-->
            </Border>
            <!--  Sitzungstage  -->
            <MD:Card
                Grid.Row="2"
                Grid.Column="0"
                Margin="5,5,5,5"
                Visibility="{Binding ShowSitzungstage, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Style="{StaticResource DataGrid_Header_Stackpanel}">
                        <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Sitzungstage" />
                        <Button
                            Command="{Binding Path=DataContext.SubscribeCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                            CommandParameter="Add_Sitzung"
                            Style="{StaticResource Button_Sitzungstage}"
                            ToolTip="Anlegen eines neuen Sitzungstages">
                            <MD:PackIcon Kind="Add" />
                        </Button>
                    </StackPanel>
                    <DataGrid
                        Grid.Row="1"
                        ItemsSource="{Binding SitzungstageList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedItem="{Binding SelectedSitzungstage, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource Datagrid_Sitzungsunterlagen}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                MinWidth="90"
                                                Style="{StaticResource Datagrid_Sitzungsunterlagen_Textblock_Row}"
                                                Text="{Binding Anzeigedatum, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button
                                                x:Name="Btn_Bin_Sitzung"
                                                Command="{Binding Path=DataContext.BinCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="Bin_Sitzung"
                                                Style="{StaticResource Button_Sitzungsunterlagen_Menu}"
                                                ToolTip="Sitzungstag löschen">
                                                <MD:PackIcon Kind="Bin" Style="{StaticResource Button_Sitzungsunterlagen_Menu_PackIcon}" />
                                            </Button>
                                            <Button
                                                x:Name="Btn_Edit_Sitzung"
                                                Command="{Binding Path=DataContext.SubscribeCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="Edit_Sitzung"
                                                Style="{StaticResource Button_Sitzungsunterlagen_Menu}"
                                                ToolTip="Sitzungstag umbenennen">
                                                <MD:PackIcon Kind="Edit" Style="{StaticResource Button_Sitzungsunterlagen_Menu_PackIcon}" />
                                            </Button>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridCell}}, Path=IsSelected}" Value="true">
                                                <Setter TargetName="Btn_Bin_Sitzung" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="Btn_Edit_Sitzung" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <!--<DataGridColumn.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Sitzungstage" />
                                        <Button
                                            Command="{Binding Path=DataContext.SubscribeCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            CommandParameter="Add_Sitzung"
                                            Style="{StaticResource Button_Sitzungstage}"
                                            ToolTip="Anlegen eines neuen Sitzungstages">
                                            <MD:PackIcon Kind="Add" />
                                        </Button>
                                    </StackPanel>
                                </DataGridColumn.Header>-->
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <CheckBox
                        Grid.Row="2"
                        Margin="15,0,0,0"
                        HorizontalAlignment="Left"
                        IsChecked="{Binding SitzungstagePast}">
                        <TextBlock Text="Erledigte Sitzungstage ausblenden" TextWrapping="Wrap" />
                    </CheckBox>

                </Grid>
            </MD:Card>
            <!--  Verfahren  -->
            <GridSplitter
                Grid.Row="2"
                Grid.Column="1"
                Style="{StaticResource Gridsplitter_Sitzungsunterlagen}"
                Visibility="{Binding ShowVerfahren, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
            <MD:Card
                Name="Card_Verfahren"
                Grid.Row="2"
                Grid.Column="2"
                Margin="5,5,5,5"
                IsEnabled="{Binding ShowEnableCards, UpdateSourceTrigger=PropertyChanged}"
                Visibility="{Binding ShowVerfahren, Converter={StaticResource BoolToVisConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!--  Header  -->
                    <StackPanel Grid.Row="0" Orientation="Vertical">
                        <WrapPanel Style="{StaticResource DataGrid_Header_Wrappanel}">
                            <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Verfahren" />
                            <Button
                                Command="{Binding Path=DataContext.SubscribeCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                CommandParameter="Add_Verfahren"
                                Style="{StaticResource Button_Sitzungstage_MarginRigh}"
                                ToolTip="Anlegen eines neuen Verfahrens">
                                <MD:PackIcon Kind="Add" />
                            </Button>
                            <CheckBox
                                Content="Filter/Sortierung anzeigen"
                                IsChecked="{Binding ShowFilterOrderBy, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource Checkbox_Base}" />
                        </WrapPanel>
                        <Border
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,1,0,1"
                            Visibility="{Binding ShowFilterOrderBy, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>
                                <!--  Filter  -->
                                <Grid Grid.Column="0" Grid.ColumnSpan="2">
                                    <Border
                                        Margin="0,3"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        BorderThickness="0,0,1,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource DataGrid_Header_Textblock}" Text="Filter" />
                                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                                                <StackPanel Margin="5" Orientation="Vertical">
                                                    <RadioButton
                                                        x:Name="Rbtn_Alles"
                                                        Margin="0,0,0,5"
                                                        IsChecked="{Binding FilterAll, UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBlock Margin="10,0,0,0" Text="Alles" />
                                                    </RadioButton>
                                                    <RadioButton
                                                        Name="Rbtn_Filter"
                                                        Margin="0,5,0,0"
                                                        IsChecked="{Binding FilterSpruchgruppe, UpdateSourceTrigger=PropertyChanged}">
                                                        <ComboBox
                                                            Width="80"
                                                            Margin="10,0,0,0"
                                                            DisplayMemberPath="SenatSpruchgruppeAnzeige"
                                                            ItemsSource="{Binding SpruchgruppenList, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectedItem="{Binding SelectedSpruchgruppe, UpdateSourceTrigger=PropertyChanged}" />
                                                    </RadioButton>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!--  Order by  -->
                                <StackPanel
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Margin="26,0,0,0">
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Style="{StaticResource DataGrid_Header_Textblock}"
                                        Text="Sortierung" />
                                    <ComboBox
                                        Grid.Row="1"
                                        Width="120"
                                        Margin="10,0,0,10"
                                        ItemsSource="{Binding SortingList, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedItem="{Binding SelectedSorting, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource Combobox_Base}" />

                                </StackPanel>

                            </Grid>
                        </Border>
                    </StackPanel>
                    <DataGrid
                        Grid.Row="1"
                        ItemsSource="{Binding VerfahrenView, UpdateSourceTrigger=PropertyChanged}"
                        SelectedItem="{Binding SelectedVerfahren, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource Datagrid_Sitzungsunterlagen}">
                        <!--<DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRowsPresenter}">
                                <Setter Property="Height" Value="{x:Static sys:Double.NaN}" />
                            </Style>
                        </DataGrid.RowStyle>-->

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <WrapPanel
                                            Height="100"
                                            Orientation="Horizontal"
                                            Visibility="{Binding ShowVerfahrenDetails, Converter={StaticResource BoolToVisConverter}}">
                                            <CheckBox
                                                x:Name="Txt_Unterlagen"
                                                Margin="0,-10,10,0"
                                                VerticalAlignment="Center"
                                                Background="White"
                                                Foreground="White"
                                                IsChecked="{Binding Verteilt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource CheckBoxStyle1}"
                                                ToolTip="Anwählen, wenn die Unterlagen für das Verfahren verteilt worden."
                                                Visibility="{Binding Anzeige_Verteilung, Converter={StaticResource BoolToVisConverter}}" />
                                            <TextBlock
                                                MinWidth="130"
                                                Margin="0,2,0,0"
                                                Style="{StaticResource Datagrid_Sitzungsunterlagen_Textblock_Row}"
                                                Text="{Binding Verfahren_Anzeigedaten}" />
                                            <TextBlock
                                                Margin="0,2,10,0"
                                                Style="{StaticResource Datagrid_Sitzungsunterlagen_Textblock_Row}"
                                                Text="{Binding Spruchgruppe.SenatSpruchgruppeAnzeige}" />
                                            <Button
                                                x:Name="Btn_Bin_Verfahren"
                                                Command="{Binding Path=DataContext.BinCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="Bin_Verfahren"
                                                Style="{StaticResource Button_Sitzungsunterlagen_Menu_Margin}"
                                                ToolTip="Verfahren löschen">
                                                <MD:PackIcon Kind="Bin" Style="{StaticResource Button_Sitzungsunterlagen_Menu_PackIcon}" />
                                            </Button>
                                            <Button
                                                x:Name="Btn_Edit_Verfahren"
                                                Command="{Binding Path=DataContext.SubscribeCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="Edit_Verfahren"
                                                Style="{StaticResource Button_Sitzungsunterlagen_Menu_Margin}"
                                                ToolTip="Verfahren umbenennen">
                                                <MD:PackIcon Kind="Edit" Style="{StaticResource Button_Sitzungsunterlagen_Menu_PackIcon}" />
                                            </Button>
                                            <Button
                                                x:Name="Btn_Import_Verfahren"
                                                Command="{Binding Path=DataContext.ImportCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="Import_Mainview"
                                                Style="{StaticResource Button_Sitzungsunterlagen_Menu_Margin}"
                                                ToolTip="Um mehrere Dokumente gleichzeit zu importieren, wird ein Importordner erstellt.">
                                                <MD:PackIcon Kind="Import" Style="{StaticResource Button_Sitzungsunterlagen_Menu_PackIcon}" />
                                            </Button>
                                            <Button
                                                x:Name="Btn_Votenmappe_Verfahren"
                                                Margin="5,2,0,5"
                                                Command="{Binding Path=DataContext.ImportCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="Votenmappe"
                                                Style="{StaticResource Button_Sitzungsunterlagen_Menu_Margin}"
                                                ToolTip="Verfahren in die Votenmappe legen.">
                                                <MD:PackIcon Kind="DownloadBoxOutline" Style="{StaticResource Button_Sitzungsunterlagen_Menu_PackIcon}" />
                                            </Button>
                                        </WrapPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridCell}}, Path=IsSelected}" Value="true">
                                                <Setter TargetName="Btn_Bin_Verfahren" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="Btn_Edit_Verfahren" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="Btn_Import_Verfahren" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="Btn_Votenmappe_Verfahren" Property="Visibility" Value="Visible" />
                                                <!--<Setter TargetName="ckb_Verteilt" Property="Margin" Value="0,5,5,0" />-->
                                                <Setter TargetName="Txt_Unterlagen" Property="MaxWidth" Value="180" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
