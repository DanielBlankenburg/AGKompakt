<UserControl
    x:Class="BGH_Kompakt.Views.SitzungsplaeneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Background="{StaticResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Margin="0,10,0,0"
            FontFamily="{StaticResource MaterialDesignFont}"
            FontSize="30"
            FontWeight="Bold"
            Text="Sitzungsdienste"
            TextAlignment="Center" />
        <Border
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Height="50"
            Margin="3,14,3,16"
            BorderThickness="0,0,0,1"
            Style="{StaticResource Style_Border_Color}">
            <MD:Card
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="750"
                Margin="5,0,0,10"
                HorizontalAlignment="Center">
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Height="40"
                    Margin="30,0,0,0"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,10,20,0"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="16"
                        FontWeight="Medium"
                        Text="Bitte wählen Sie einen Jahrgang aus:"
                        TextAlignment="Center" />
                    <ComboBox
                        x:Name="Cbo_Jahr"
                        Width="100"
                        HorizontalContentAlignment="Center"
                        DisplayMemberPath="Jahr"
                        DropDownClosed="Cbo_Jahr_DropDownClosed"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="16"
                        SelectedValue="Name" />
                </StackPanel>
            </MD:Card>
        </Border>
        <MD:Card
            Grid.Row="2"
            Width="600"
            Margin="5">
            <DataGrid
                Name="UserDataGrid"
                Width="550"
                HorizontalScrollBarVisibility="Disabled"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="150"
                        Binding="{Binding AnzeigeDatum}"
                        Header="Datum" />
                    <DataGridTextColumn
                        Width="220"
                        Binding="{Binding HiWiNameZitat}"
                        Header="Zitatkontrolle" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding HiWiNameGuide}"
                        Header="Führung" />
                </DataGrid.Columns>
            </DataGrid>
        </MD:Card>
    </Grid>
</UserControl>
