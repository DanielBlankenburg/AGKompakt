<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls">

    <!--#region Datepicker-->
    <Style
        x:Key="Datepicker_Base"
        BasedOn="{StaticResource MaterialDesignDatePicker}"
        TargetType="{x:Type DatePicker}">
        <Setter Property="Control.FontFamily" Value="{DynamicResource MaterialDesignFont}" />
        <Setter Property="Control.FontSize" Value="{DynamicResource BaseFontSize}" />
        <Setter Property="MD:HintAssist.Foreground" Value="DarkGray" />
        <Setter Property="MD:HintAssist.HintOpacity" Value=".5" />
        <Setter Property="MD:HintAssist.IsFloating" Value="True" />
        <Setter Property="MD:HintAssist.FloatingScale" Value=".8" />
        <Setter Property="MD:HintAssist.FloatingOffset" Value="1,-18" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Cursor" Value="Hand" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--#endregion-->

</ResourceDictionary>