<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:Slider="clr-namespace:BGH_Kompakt.Classes">

    <!--#region Sliderbutton-->

    <Style x:Key="styleEllipseButton" TargetType="{x:Type Ellipse}">
        <Setter Property="Stroke" Value="Gray" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style
        x:Key="styleEllipseGreyButton"
        BasedOn="{StaticResource styleEllipseButton}"
        TargetType="{x:Type Ellipse}">
        <Setter Property="Fill">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0.504,0.03" EndPoint="0.504,1.5">
                    <GradientStop Offset="0" Color="#FFFFFF" />
                    <GradientStop Offset="0.567" Color="#BBBBBB" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="styleSliderButtonLabel" TargetType="{x:Type Label}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="styleSliderButtonSideLabel" TargetType="{x:Type Slider:SliderButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider:SliderButton}">
                    <Grid x:Name="mainGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid
                            Name="_borderOn"
                            Grid.Column="2"
                            Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                Panel.ZIndex="3"
                                Style="{StaticResource styleEllipseGreyButton}" />
                            <Border
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Panel.ZIndex="1"
                                Background="ForestGreen"
                                BorderBrush="Gray"
                                BorderThickness="0,1,0,1" />
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                Panel.ZIndex="0"
                                Fill="ForestGreen"
                                Style="{StaticResource styleEllipseButton}" />
                        </Grid>
                        <Label
                            Name="_labelOn"
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="{TemplateBinding OnLabel}"
                            Foreground="Black"
                            Style="{StaticResource styleSliderButtonLabel}" />

                        <Grid
                            Name="_borderOff"
                            Grid.Column="2"
                            Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                VerticalAlignment="Stretch"
                                Panel.ZIndex="0"
                                Fill="Crimson"
                                Stroke="Gray" />
                            <Border
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Panel.ZIndex="1"
                                Background="Crimson"
                                BorderBrush="Gray"
                                BorderThickness="0,1,0,1" />
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                Panel.ZIndex="3"
                                Style="{StaticResource styleEllipseGreyButton}" />
                        </Grid>
                        <Label
                            Name="_labelOff"
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="{TemplateBinding OffLabel}"
                            Foreground="Black"
                            Style="{StaticResource styleSliderButtonLabel}" />
                    </Grid>

                    <!--  triggers toggle visual appearance  -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="_labelOff" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="_borderOff" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="_labelOn" Property="Visibility" Value="Visible" />
                            <Setter TargetName="_borderOn" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="_labelOff" Property="Visibility" Value="Visible" />
                            <Setter TargetName="_borderOff" Property="Visibility" Value="Visible" />
                            <Setter TargetName="_labelOn" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="_borderOn" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="styleSliderButton" TargetType="{x:Type Slider:SliderButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider:SliderButton}">
                    <Grid x:Name="mainGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid
                            Name="_borderOn"
                            Grid.Column="0"
                            Width="{TemplateBinding Width}"
                            Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                Panel.ZIndex="3"
                                Style="{StaticResource styleEllipseGreyButton}" />
                            <Border
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Panel.ZIndex="1"
                                Background="MidnightBlue"
                                BorderBrush="Gray"
                                BorderThickness="0,1,0,1" />
                            <Label
                                Name="_labelOn"
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="2"
                                Grid.ColumnSpan="3"
                                Panel.ZIndex="2"
                                Content="{TemplateBinding OnLabel}"
                                Style="{StaticResource styleSliderButtonLabel}" />
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                Panel.ZIndex="0"
                                Fill="MidnightBlue"
                                Style="{StaticResource styleEllipseButton}" />
                        </Grid>

                        <Grid
                            Name="_borderOff"
                            Grid.Column="0"
                            Width="{TemplateBinding Width}"
                            Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                VerticalAlignment="Stretch"
                                Panel.ZIndex="0"
                                Fill="LightGray"
                                Stroke="Gray" />
                            <Label
                                Name="_labelOff"
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Panel.ZIndex="2"
                                Content="{TemplateBinding OffLabel}"
                                Style="{StaticResource styleSliderButtonLabel}" />
                            <Border
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="3"
                                Panel.ZIndex="1"
                                Background="LightGray"
                                BorderBrush="Gray"
                                BorderThickness="0,1,0,1" />
                            <Ellipse
                                Grid.Row="0"
                                Grid.RowSpan="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Width="{TemplateBinding ButtonWidth}"
                                Height="{TemplateBinding ButtonWidth}"
                                Panel.ZIndex="3"
                                Style="{StaticResource styleEllipseGreyButton}" />
                        </Grid>
                    </Grid>

                    <!--  triggers toggle visual appearance  -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="_borderOff" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="_borderOn" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="_borderOff" Property="Visibility" Value="Visible" />
                            <Setter TargetName="_borderOn" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="styleSliderButtonSettings"
        BasedOn="{StaticResource styleSliderButton}"
        TargetType="{x:Type Slider:SliderButton}">
        <Setter Property="Width" Value="50" />
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="ButtonWidth" Value="20" />
        <Setter Property="OffLabel" Value="Aus" />
        <Setter Property="OnLabel" Value="An" />
    </Style>

    <Style
        x:Key="styleSliderButton_Filter"
        BasedOn="{StaticResource styleSliderButton}"
        TargetType="Slider:SliderButton">
        <Setter Property="Margin" Value="5,5,0,0" />
        <Setter Property="Width" Value="50" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="OnLabel" Value="" />
        <Setter Property="OffLabel" Value="" />
        <Setter Property="ButtonWidth" Value="20" />
    </Style>

    <Style x:Key="styleBorderGreyButton" TargetType="{x:Type Border}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0.504,0.03" EndPoint="0.504,1.5">
                    <GradientStop Offset="0" Color="#FFFFFF" />
                    <GradientStop Offset="0.567" Color="#BBBBBB" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="Gray" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="styleSliderButtonRectangular" TargetType="{x:Type Slider:SliderButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider:SliderButton}">
                    <Grid
                        x:Name="mainGrid"
                        HorizontalAlignment="Stretch"
                        Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Name="_borderOn"
                            Grid.Column="0"
                            VerticalAlignment="Stretch"
                            Background="ForestGreen"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    CornerRadius="0"
                                    Style="{StaticResource styleBorderGreyButton}" />
                                <Label
                                    Name="_labelOn"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Content="{TemplateBinding OnLabel}"
                                    Style="{StaticResource styleSliderButtonLabel}" />
                            </Grid>
                        </Border>

                        <Border
                            Name="_borderOff"
                            Grid.Column="0"
                            VerticalAlignment="Stretch"
                            Background="Crimson"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    Name="_labelOff"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Content="{TemplateBinding OffLabel}"
                                    Style="{StaticResource styleSliderButtonLabel}" />
                                <Border
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    CornerRadius="0"
                                    Style="{StaticResource styleBorderGreyButton}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!--  triggers toggle visual appearance  -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="_borderOff" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="_borderOn" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="_borderOff" Property="Visibility" Value="Visible" />
                            <Setter TargetName="_borderOn" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->


</ResourceDictionary>