<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--#region Textblock-->

    <Style x:Key="textblock_base" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource MaterialDesignFont}" />
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style
        x:Key="Style_ListView_Header"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Foreground" Value="Black" />
    </Style>

    <Style
        x:Key="Style_Version"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="10,0,0,0" />
    </Style>

    <Style
        x:Key="Style_Textblock_Titel"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="35" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="Style_Textblock_Titel_Unter1"
        BasedOn="{StaticResource Style_Textblock_Titel}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="25" />
    </Style>

    <Style
        x:Key="Style_Textblock_Titel_Unter2"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="Style_Textblock_Titel_Unter3"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style
        x:Key="Style_Textbox_Button"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="Black" />
    </Style>

    <Style
        x:Key="Style_Textblock_Spruchgruppen"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Margin" Value="10,0,0,0" />
    </Style>

    <Style
        x:Key="Style_Textblock_SignDiscription"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FrameworkElement.Margin" Value="10,0,0,0" />
    </Style>

    <Style
        x:Key="Style_Textblock_Eingabefenster"
        BasedOn="{StaticResource MaterialDesignTextBlock}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FrameworkElement.VerticalAlignment" Value="Center" />
        <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center" />
        <Setter Property="TextBlock.FontSize" Value="16" />
        <Setter Property="FrameworkElement.Margin" Value="0,10,0,10" />
        <Setter Property="TextBlock.FontFamily" Value="{StaticResource MaterialDesignFont}" />
    </Style>

    <Style
        x:Key="Button_Mainwindow_Textblock"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="TextBlock.FontSize" Value="18" />
        <Setter Property="Height" Value="45" />
        <Setter Property="TextBlock.TextAlignment" Value="center" />
        <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
        <Setter Property="TextBlock.FontWeight" Value="Medium" />
        <Setter Property="Margin" Value="0,15,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="Style_Textblock_AZ"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="15,10,10,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style
        x:Key="Style_Textblock_Button"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="Height" Value="auto" />
        <Setter Property="Margin" Value="10,0,0,5" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style
        x:Key="Style_Textblock_Button_BSCW"
        BasedOn="{StaticResource Style_Textblock_Button}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="10,0,0,2" />
    </Style>

    <Style
        x:Key="Style_Textbox_FilterSlider"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="10,7,0,0" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style
        x:Key="Style_Textblock_Montagspost_Lable"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Margin" Value="0,0,20,0" />
        <Setter Property="TextAlignment" Value="Left" />
    </Style>

    <Style x:Key="Style_Card_Content_Textblock" TargetType="{x:Type TextBlock}">
        <Setter Property="Padding" Value="5,5,0,0" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextAlignment" Value="left" />
    </Style>

    <Style x:Key="Style_Textbox_Error" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="Red" />
    </Style>

    <Style
        x:Key="Style_MainWindow_Statusbar"
        BasedOn="{StaticResource textblock_base}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="15,0,0,0" />
        <Setter Property="FontSize" Value="20" />
    </Style>
    <!--#endregion-->

</ResourceDictionary>