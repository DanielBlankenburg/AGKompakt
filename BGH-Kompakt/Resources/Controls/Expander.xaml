<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Style x:Key="Textblock_Extender" TargetType="{x:Type TextBlock}">
        <!--<Setter Property="Margin" Value="0,0,0,30" />-->
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="Stackpanel_Expander" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="40,10,24,16" />
        <Setter Property="MinWidth" Value="500" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Orientation" Value="Vertical" />
    </Style>

    <Style x:Key="Expander_Border" TargetType="{x:Type Border}">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource MaterialDesignDivider}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Expander_Border_Vertical" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{StaticResource MaterialDesignDivider}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Stackpanel_Expander_Buttons" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="15,20,0,10" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>



</ResourceDictionary>