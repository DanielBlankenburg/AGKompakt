<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls">

    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.StrokeOff" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.StrokeOffPointerOver" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.StrokeOffPressed" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.StrokeOn" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.StrokeOnPointerOver" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.StrokeOnPressed" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.KnobFillOff" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.KnobFillOffPressed" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.KnobFillOffPointerOver" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.FillOn" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.FillOnPointerOver" Color="SlateGray" />
    <SolidColorBrush x:Key="MahApps.Brushes.ToggleSwitch.FillOnPressed" Color="SlateGray" />


    <Style x:Key="ToggleSwitchMaster" TargetType="{x:Type MW:ToggleSwitch}">
        <Setter Property="OffContent" Value="Nein" />
        <Setter Property="OnContent" Value="Ja" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <Style
        x:Key="ToggleSwitchMaster_Left"
        BasedOn="{StaticResource ToggleSwitchMaster}"
        TargetType="{x:Type MW:ToggleSwitch}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
    </Style>

    <Style
        x:Key="ToggleSwitchMaster_Right"
        BasedOn="{StaticResource ToggleSwitchMaster}"
        TargetType="{x:Type MW:ToggleSwitch}">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
    </Style>

</ResourceDictionary>