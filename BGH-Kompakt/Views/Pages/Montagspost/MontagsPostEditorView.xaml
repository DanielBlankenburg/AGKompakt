<UserControl
    x:Class="BGH_Kompakt.Views.Pages.Montagspost.MontagsPostEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.Montagspost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montagspost="clr-namespace:BGH_Kompakt.ViewModel.Montagspost"
    d:DataContext="{d:DesignInstance Type=montagspost:MontagsPostEditorViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Background="{StaticResource MaterialDesignPaper}"
    Language="de-DE"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="GridMain" TargetType="Grid">
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style
            x:Key="TextMPEditLabelProperties"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="0,17,0,0" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style
            x:Key="TextMPEditTextboxProperties"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="TextBox">
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style
            x:Key="TextMPEditCombobox"
            BasedOn="{StaticResource Combobox_Base}"
            TargetType="ComboBox">
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MaxWidth" Value="350" />
        </Style>

    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            Margin="0,10,0,20"
            Style="{StaticResource Style_Textblock_Titel_Unter1}"
            Text="Montagspost Editor" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" MinWidth="190" />
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!--  Kalenderwoche  -->
                <MD:Card Grid.Row="0" Style="{StaticResource MDCard_Master}">

                    <Grid Style="{StaticResource GridMain}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource Style_Textblock_Titel_Unter3}" Text="Kalenderwoche" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,8,20,0"
                                FontFamily="{StaticResource MaterialDesignFont}"
                                FontSize="14"
                                FontWeight="Medium"
                                Text="Jahrgang:"
                                TextAlignment="Center" />
                            <ComboBox
                                x:Name="Cbo_Jahr"
                                HorizontalContentAlignment="Left"
                                FontFamily="{StaticResource MaterialDesignFont}"
                                FontSize="14"
                                ItemsSource="{Binding VintageList}"
                                SelectedItem="{Binding SelectedVintage, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <ListBox
                            Grid.Row="2"
                            Margin="0,10,0,0"
                            Padding="5,20,0,0"
                            DisplayMemberPath="MPWeekName"
                            ItemsSource="{Binding MPWeekList}"
                            SelectedItem="{Binding SelectedWeek, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </MD:Card>
                <!--  Entscheidungen  -->
                <MD:Card Grid.Row="1" Style="{StaticResource MDCard_Master}">
                    <Grid Style="{StaticResource GridMain}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource Style_Textblock_Titel_Unter3}"
                            Text="Entscheidungen" />
                        <ListBox
                            Grid.Row="1"
                            Margin="15,0,0,0"
                            Padding="5,20,0,0"
                            DisplayMemberPath="Aktenzeichen"
                            ItemsSource="{Binding MPDecisionList}"
                            SelectedItem="{Binding SelecteDecision, UpdateSourceTrigger=PropertyChanged}" />

                    </Grid>
                </MD:Card>
            </Grid>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="50" />
                </Grid.RowDefinitions>
                <MD:Card
                    x:Name="Entscheidungsdaten"
                    Grid.Column="2"
                    Style="{StaticResource MDCard_Master}">
                    <ScrollViewer Height="{Binding ElementName=Entscheidungsdaten, Path=ActualHeight}" VerticalScrollBarVisibility="Visible">
                        <Grid Style="{StaticResource GridMain}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                HorizontalAlignment="Center"
                                Style="{StaticResource Style_Textblock_Titel_Unter3}"
                                Text="Entscheidungsdaten" />
                            <Grid Grid.Row="1" DataContext="{Binding EditDecision}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <!--  Datum  -->
                                <TextBlock
                                    Grid.Row="0"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Datum:" />
                                <TextBox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    MaxWidth="100"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding Date, StringFormat=d}" />
                                <!--  Typ  -->
                                <TextBlock
                                    Grid.Row="1"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Typ:" />
                                <StackPanel
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,16,0,0"
                                    Orientation="Horizontal">
                                    <RadioButton
                                        Margin="0,0,10,0"
                                        Content="Urteil"
                                        IsChecked="{Binding Typ, Converter={StaticResource radioBoolToIntConverter}, ConverterParameter=1}"
                                        Style="{StaticResource RadioButton_Base}" />
                                    <RadioButton
                                        Content="Beschluss"
                                        IsChecked="{Binding Typ, Converter={StaticResource radioBoolToIntConverter}, ConverterParameter=2}"
                                        Style="{StaticResource RadioButton_Base}" />
                                </StackPanel>
                                <!--<TextBox
                                    Grid.Row="1"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding Typ}" />-->
                                <!--  Senat  -->
                                <TextBlock
                                    Grid.Row="2"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Senat:" />
                                <ComboBox
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    DisplayMemberPath="MPSenatName"
                                    ItemsSource="{Binding Path=DataContext.SenatList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                    SelectedItem="{Binding Senat}"
                                    Style="{StaticResource TextMPEditCombobox}" />

                                <!--  RegZeichen  -->
                                <TextBlock
                                    Grid.Row="3"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Registerzeichen:" />
                                <TextBox
                                    Grid.Row="3"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding RegZeichen}" />

                                <!--  Laufende Nummer  -->
                                <TextBlock
                                    Grid.Row="4"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Laufende Nummer:" />
                                <TextBox
                                    Grid.Row="4"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding LaufendeNummer}" />
                                <!--  Jahr  -->
                                <TextBlock
                                    Grid.Row="5"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Jahr:" />
                                <TextBox
                                    Grid.Row="5"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding Jahr}" />
                                <!--  Rechtsgebiet  -->
                                <TextBlock
                                    Grid.Row="6"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Rechtsgebiet:" />
                                <TextBox
                                    Grid.Row="6"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding Rechtsgebiet}" />
                                <!--  Leitsatz  -->
                                <TextBlock
                                    Grid.Row="7"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Leitsatz:" />
                                <TextBox
                                    Grid.Row="7"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding Leitsatz}" />
                                <!--  Normenkette  -->
                                <TextBlock
                                    Grid.Row="8"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="Normenkette:" />
                                <TextBox
                                    Grid.Row="8"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding Normenkette}" />
                                <!--  1. Instanz  -->
                                <TextBlock
                                    Grid.Row="9"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="1. Instanz:" />
                                <TextBox
                                    Grid.Row="9"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding InstanzErste}" />
                                <!--  2. Instanz  -->
                                <TextBlock
                                    Grid.Row="10"
                                    Style="{StaticResource TextMPEditLabelProperties}"
                                    Text="2.Instanz:" />
                                <TextBox
                                    Grid.Row="10"
                                    Style="{StaticResource TextMPEditTextboxProperties}"
                                    Text="{Binding InstanzZweite}" />
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </MD:Card>
                <Button
                    Grid.Row="1"
                    Margin="5,0"
                    Command="{Binding SaveCommand}"
                    Content="Änderungen Speichern"
                    Style="{StaticResource Button_Master}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
