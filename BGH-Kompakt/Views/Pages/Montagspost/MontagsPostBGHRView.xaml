<UserControl
    x:Class="BGH_Kompakt.Views.Pages.Montagspost.MontagsPostBGHRView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.Montagspost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Background="{StaticResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="20"
            FontWeight="Bold"
            Text="Benachrichtigung BGHR" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <MD:Card Grid.Column="1" Style="{StaticResource MDCard_Master}">

                <StackPanel
                    Margin="10,10,10,0"
                    HorizontalAlignment="Left"
                    Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,8,20,0"
                            FontFamily="{StaticResource MaterialDesignFont}"
                            FontSize="16"
                            FontWeight="Medium"
                            Text="Jahrgang:"
                            TextAlignment="Center" />
                        <ComboBox
                            x:Name="Cbo_Jahr"
                            HorizontalContentAlignment="Left"
                            FontFamily="{StaticResource MaterialDesignFont}"
                            FontSize="16"
                            ItemsSource="{Binding VintageList}"
                            SelectedItem="{Binding SelectedVintage, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <ListBox
                        Padding="5,20,0,0"
                        DisplayMemberPath="MPWeekName"
                        ItemsSource="{Binding MPWeekList}"
                        SelectedItem="{Binding SelectedWeek, UpdateSourceTrigger=PropertyChanged}" />

                </StackPanel>
            </MD:Card>

            <MD:Card Grid.Column="2" Style="{StaticResource MDCard_Master}">

                <ListView
                    Margin="10,10,10,0"
                    ItemsSource="{Binding MPDecisionBEList}"
                    SelectedItem="{Binding SelectedBE}"
                    SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn
                                Width="130"
                                DisplayMemberBinding="{Binding Decision.Aktenzeichen, TargetNullValue=[keine Angabe]}"
                                Header="Entscheidung"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                            <GridViewColumn
                                Width="130"
                                DisplayMemberBinding="{Binding BE.FullSurname, TargetNullValue=[keine BE gesetzt]}"
                                Header="BE"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                            <GridViewColumn
                                Width="150"
                                Header="Inaktiv"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            x:Name="cboBE"
                                            MinWidth="100"
                                            DisplayMemberPath="FullSurname"
                                            ItemsSource="{Binding Path=DataContext.MPBEList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            SelectedItem="{Binding BE}">

                                            <!--<i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Selected">
                                                    <i:InvokeCommandAction Command="{Binding Path=DataContext.BECommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" CommandParameter="{Binding ElementName=cboBE, Path=SelectedItem}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>-->

                                        </ComboBox>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn
                                Width="150"
                                Header="Alternative"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            x:Name="cboBE"
                                            MinWidth="100"
                                            DisplayMemberPath="FullSurname"
                                            ItemsSource="{Binding Path=DataContext.MPBEList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            SelectedItem="{Binding BE}">

                                            <!--<i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Selected">
                                                    <i:InvokeCommandAction Command="{Binding Path=DataContext.BECommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" CommandParameter="{Binding ElementName=cboBE, Path=SelectedItem}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>-->

                                        </ComboBox>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </MD:Card>
        </Grid>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Margin="0,0,10,0"
                Command="{Binding SaveCommand}"
                Content="Berichterstatter speichern"
                Style="{StaticResource Button_Master}" />
        </StackPanel>

    </Grid>
</UserControl>
