<UserControl
    x:Class="BGH_Kompakt.Views.Pages.Montagspost.MontagsPostBGHRView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.Montagspost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montagspost="clr-namespace:BGH_Kompakt.ViewModel.Montagspost"
    d:DataContext="{d:DesignInstance Type=montagspost:MontagsPostBGHRViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Background="{StaticResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Button_MP_View_RowButton"
            BasedOn="{StaticResource MaterialDesignFlatButton}"
            TargetType="Button">
            <Setter Property="Width" Value="35" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="15,4,0,5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="Stackpanal_Settings" TargetType="StackPanel">
            <Setter Property="Margin" Value="10,10,10,0" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="20"
            FontWeight="Bold"
            Text="Benachrichtigung BGHR" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <MD:Card Grid.Column="1" Style="{StaticResource MDCard_Master}">

                <StackPanel
                    Margin="10,10,10,0"
                    HorizontalAlignment="Left"
                    Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,8,20,0"
                            FontFamily="{StaticResource MaterialDesignFont}"
                            FontSize="16"
                            FontWeight="Medium"
                            Text="Jahrgang:"
                            TextAlignment="Center" />
                        <ComboBox
                            x:Name="Cbo_Jahr"
                            HorizontalContentAlignment="Left"
                            FontFamily="{StaticResource MaterialDesignFont}"
                            FontSize="16"
                            ItemsSource="{Binding VintageList}"
                            SelectedItem="{Binding SelectedVintage, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <ListBox
                        Margin="0,10,0,0"
                        Padding="5,20,0,0"
                        DisplayMemberPath="MPWeekName"
                        ItemsSource="{Binding MPWeekList}"
                        SelectedItem="{Binding SelectedWeek, UpdateSourceTrigger=PropertyChanged}" />

                </StackPanel>
            </MD:Card>

            <MD:Card Grid.Column="2" Style="{StaticResource MDCard_Master}">

                <ListView
                    Margin="10,10,10,0"
                    ItemsSource="{Binding MPDecisionBEList}"
                    SelectedItem="{Binding SelectedBE}"
                    SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn
                                Width="110"
                                DisplayMemberBinding="{Binding Decision.Aktenzeichen, TargetNullValue=[keine Angabe]}"
                                Header="Entscheidung"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                            <GridViewColumn
                                Width="150"
                                DisplayMemberBinding="{Binding BE.Fullname, TargetNullValue=[keine BE gesetzt]}"
                                Header="BE"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                            <GridViewColumn
                                Width="70"
                                Header="Inaktiv"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding BE.IsInactiv, Mode=OneWay}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn
                                Width="150"
                                Header="Anderer Empfänger"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            x:Name="cboBE"
                                            MinWidth="100"
                                            DisplayMemberPath="Fullname"
                                            ItemsSource="{Binding Path=DataContext.MPBEList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            SelectedItem="{Binding BEAlternative}"
                                            Visibility="{Binding BE.IsInactiv, Converter={StaticResource BooleanToVisibilityConverter}}">

                                            <!--<i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Selected">
                                                    <i:InvokeCommandAction Command="{Binding Path=DataContext.BECommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" CommandParameter="{Binding ElementName=cboBE, Path=SelectedItem}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>-->

                                        </ComboBox>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn
                                Width="100"
                                Header="Versand?"
                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox Margin="30,0,0,0" IsChecked="{Binding Decision.BEEMail, Mode=OneWay}" />
                                            <Button
                                                x:Name="Btn_Reset"
                                                Command="{Binding Path=DataContext.ResetCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                Style="{StaticResource Button_MP_View_RowButton}"
                                                ToolTip="Versand zurücksetzen"
                                                Visibility="Hidden">

                                                <MD:PackIcon Padding="0" Kind="BackupRestore" />
                                            </Button>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=IsSelected}" Value="true">
                                                <Setter TargetName="Btn_Reset" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>

                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                        </GridView>
                    </ListView.View>
                </ListView>
            </MD:Card>
            <MD:Card Grid.Column="3" Style="{StaticResource MDCard_Master}">
                <StackPanel>
                    <TextBlock
                        Margin="0,10,0,10"
                        Style="{StaticResource Style_Textblock_Titel_Unter2}"
                        Text="Einstellungen" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="5,0">
                            <!--  Versandart  -->
                            <StackPanel Style="{StaticResource Stackpanal_Settings}">
                                <TextBlock
                                    Margin="0,0,15,0"
                                    FontWeight="Bold"
                                    Style="{StaticResource Style_Textblock_Titel_Unter3}"
                                    Text="Versandart:" />
                                <MW:ToggleSwitch
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    IsOn="{Binding VersandArt, UpdateSourceTrigger=PropertyChanged}"
                                    OffContent="Anzeige im Entwurf"
                                    OnContent="Direkter Versand" />
                            </StackPanel>
                            <Border Margin="0,5" Style="{StaticResource Expander_Border}" />
                            <!--  EMail  -->
                            <StackPanel Style="{StaticResource Stackpanal_Settings}">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontWeight="Bold"
                                    Style="{StaticResource Style_Textblock_Titel_Unter3}"
                                    Text="E-Mail-Text:" />
                                <StackPanel Margin="15,0,0,0">
                                    <TextBox
                                        MaxWidth="300"
                                        Margin="0,10,0,0"
                                        Style="{StaticResource Textbox_Textarea}"
                                        Text="{Binding BGHR_EMail.MPEMailBody}" />
                                    <TextBlock
                                        MaxWidth="300"
                                        Margin="0,10"
                                        FontWeight="Bold"
                                        Text="{Binding TagHint}"
                                        TextWrapping="WrapWithOverflow" />
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                            Margin="5,10"
                                            Command="{Binding SaveEMailCommand}"
                                            Content="Speichern"
                                            Style="{StaticResource Button_Master}" />
                                        <Button
                                            Margin="5,10"
                                            Command="{Binding ResetEMailCommand}"
                                            Content="Zurücksetzen"
                                            Style="{StaticResource Button_Master}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource Expander_Border_Vertical}" />
                        <!--  Senate  -->
                        <StackPanel Grid.Column="2" Margin="10,10,0,0">
                            <TextBlock Style="{StaticResource Style_Textblock_Titel_Unter3}" Text="Empfänger Senate" />
                            <StackPanel Margin="10,0,10,0">
                                <!--  List of senate  -->
                                <ListView
                                    Margin="0,0,0,15"
                                    ItemsSource="{Binding SenateRecipientList}"
                                    SelectedItem="{Binding SelectedSenatRecipient}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn
                                                DisplayMemberBinding="{Binding SenatAnzeige, TargetNullValue=[keine Angabe]}"
                                                Header="Senat"
                                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                                            <GridViewColumn
                                                DisplayMemberBinding="{Binding RecipientAnzeige, TargetNullValue=[keine Angabe]}"
                                                Header="Empfänger"
                                                HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <Border Style="{StaticResource Expander_Border}" />
                                <!--  Input  -->
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock
                                            Margin="0,0,0,5"
                                            FontWeight="Bold"
                                            Style="{StaticResource textblock_base}"
                                            Text="Senat:" />
                                        <ComboBox
                                            x:Name="Cbo_Senat"
                                            DisplayMemberPath="SenatName"
                                            ItemsSource="{Binding SenateList}"
                                            SelectedItem="{Binding SelectedSenat, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource Combobox_Base}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock
                                            Margin="0,10,0,5"
                                            FontWeight="Bold"
                                            Style="{StaticResource textblock_base}"
                                            Text="Empfänger:" />
                                        <ComboBox
                                            x:Name="Cbo_Empfaenger"
                                            DisplayMemberPath="Fullname"
                                            ItemsSource="{Binding SenatBEList}"
                                            SelectedItem="{Binding SelectedSenatBE, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource Combobox_Base}" />
                                    </StackPanel>
                                </StackPanel>
                                <!--  Buttons  -->
                                <StackPanel
                                    Margin="0,10"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        Margin="5,0"
                                        Command="{Binding AddSenateEmpfaengerCommand}"
                                        Content="Hinzufügen"
                                        Style="{StaticResource Button_Master}" />
                                    <Button
                                        Margin="5,0"
                                        Command="{Binding RemoveSenateEmpfaengerCommand}"
                                        Content="Entfernen"
                                        Style="{StaticResource Button_Master}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>

            </MD:Card>

        </Grid>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Margin="0,0,10,0"
                Command="{Binding SendCommand}"
                Content="Berichterstatter benachrichtigen"
                Style="{StaticResource Button_Master}" />
        </StackPanel>

    </Grid>
</UserControl>
