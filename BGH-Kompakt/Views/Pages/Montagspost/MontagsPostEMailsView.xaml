<UserControl
    x:Class="BGH_Kompakt.Views.Pages.Montagspost.MontagsPostEMailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.Montagspost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montagspost="clr-namespace:BGH_Kompakt.ViewModel.Montagspost"
    d:DataContext="{d:DesignInstance Type=montagspost:MontagsPostEMailsViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Background="{StaticResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Textblock_MPImport_Header"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,15,0,0" />
        </Style>
        <Style
            x:Key="Textblock_MPImport_Text"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,25,0,0" />
        </Style>
        <Style
            x:Key="Textblock_MPImpor_Under"
            BasedOn="{StaticResource Textblock_MPImport_Header}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style
            x:Key="Comobox_MPImport"
            BasedOn="{StaticResource Combobox_Base}"
            TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="15,0" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style
            x:Key="Button_MP_View_RowButton"
            BasedOn="{StaticResource MaterialDesignFlatButton}"
            TargetType="Button">
            <Setter Property="Width" Value="35" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="5,0,0,5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style
            x:Key="Button_MP_Import"
            BasedOn="{StaticResource Button_Master}"
            TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="MaxWidth" Value="170" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>
        <Style
            x:Key="Textbox_MP_Import"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="{x:Type TextBox}">
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="MaxWidth" Value="300" />
        </Style>
        <Style x:Key="Listbox_MP" TargetType="{x:Type ListBox}">
            <Setter Property="BorderBrush" Value="LightGray" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="15" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <MD:Card Grid.Column="1" Style="{StaticResource MDCard_Master}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="200" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource Textblock_MPImport_Header}" Text="Interne Empfänger (Benachrichtigung Montagspost)" />

                <ListBox
                    Grid.Row="1"
                    ItemsSource="{Binding ListInterior}"
                    SelectedItem="{Binding SelectedInteriorEMailRecipient}"
                    Style="{StaticResource Listbox_MP}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource textblock_base}"
                                    Text="{Binding MPEMailUserFullName}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource textblock_base}"
                                    Text="{Binding MPEMailRecipientAdress}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
                <Grid Grid.Row="2">
                    <StackPanel>
                        <TextBox
                            Grid.Row="0"
                            Grid.Column="0"
                            MD:HintAssist.Hint="EMail-Adresse:"
                            Style="{StaticResource Textbox_MP_Import}"
                            Text="{Binding EMailRecipientInterior, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Grid.Row="1"
                            Grid.Column="0"
                            Command="{Binding ListInteriorEditCommand}"
                            CommandParameter="pdf"
                            Content="Änderung Speichern"
                            Style="{StaticResource Button_MP_Import}" />

                    </StackPanel>
                </Grid>
            </Grid>
        </MD:Card>
        <MD:Card Grid.Column="2" Style="{StaticResource MDCard_Master}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="200" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource Textblock_MPImport_Header}" Text="Externe Empfänger" />
                <ListBox
                    Grid.Row="1"
                    ItemsSource="{Binding ListExterior}"
                    SelectedItem="{Binding SelectedExteriorEMailRecipient}"
                    Style="{StaticResource Listbox_MP}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource textblock_base}"
                                    Text="{Binding MPEMailRecipientAdress}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="15,0,0,0">
                        <TextBox
                            MD:HintAssist.Hint="EMail-Empfänger:"
                            Style="{StaticResource Textbox_MP_Import}"
                            Text="{Binding EMailRecipientExterior, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Command="{Binding ListExteriorAddCommand}"
                            Content="Hinzufügen"
                            Style="{StaticResource Button_MP_Import}" />

                    </StackPanel>
                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Command="{Binding ListExteriorDeleteCommand}"
                        Content="Löschen"
                        Style="{StaticResource Button_MP_Import}" />
                </Grid>
            </Grid>
        </MD:Card>

    </Grid>
</UserControl>
