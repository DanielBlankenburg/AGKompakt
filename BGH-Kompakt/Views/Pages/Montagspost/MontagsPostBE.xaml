<UserControl
    x:Class="BGH_Kompakt.Views.Montagspost.MontagsPostBE"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Montagspost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montagspost="clr-namespace:BGH_Kompakt.ViewModel.Montagspost"
    d:DataContext="{d:DesignInstance Type=montagspost:MontagsPostBEViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Background="{StaticResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="20"
            FontWeight="Bold"
            Text="Berichterstatter" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ListView
                x:Name="listView"
                Grid.Column="1"
                ItemsSource="{Binding MPDecisionList}"
                SelectedItem="{Binding SelectedActivityRequest}"
                SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Width="130"
                            DisplayMemberBinding="{Binding Aktenzeichen, TargetNullValue=[keine Angabe]}"
                            Header="Entscheidung"
                            HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                        <GridViewColumn
                            Width="150"
                            Header="Berichterstatter"
                            HeaderContainerStyle="{StaticResource Person_GridViewColumn}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox
                                        MinWidth="100"
                                        DisplayMemberPath="MPBEName"
                                        ItemsSource="{Binding Path=DataContext.MPBEList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                        SelectedItem="{Binding BE}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,10,0"
                Command="{Binding SaveCommand}"
                Content="Berichterstatter speichern" />
            <Button
                Margin="0,0,20,0"
                Command="{Binding BackCommand}"
                Content="Zurück ohne Speichern" />
        </StackPanel>

    </Grid>
</UserControl>
