<UserControl
    x:Class="BGH_Kompakt.Views.Montagspost.MontagspostImportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:components="clr-namespace:BGH_Kompakt.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Montagspost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montagspost="clr-namespace:BGH_Kompakt.ViewModel.Montagspost"
    d:DataContext="{d:DesignInstance Type=montagspost:MontagspostImportViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Background="{StaticResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Textblock_MPImport_Header"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,15,0,0" />
        </Style>
        <Style
            x:Key="Textblock_MPImport_Text"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,25,0,0" />
        </Style>
        <Style
            x:Key="Textblock_MPImpor_Under"
            BasedOn="{StaticResource Textblock_MPImport_Header}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style
            x:Key="Comobox_MPImport"
            BasedOn="{StaticResource Combobox_Base}"
            TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="15,0" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style
            x:Key="Button_MP_View_RowButton"
            BasedOn="{StaticResource MaterialDesignFlatButton}"
            TargetType="Button">
            <Setter Property="Width" Value="35" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="5,0,0,5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style
            x:Key="Button_MP_Import"
            BasedOn="{StaticResource Button_Master}"
            TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="MaxWidth" Value="160" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>
        <Style
            x:Key="Textbox_MP_Import"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="{x:Type TextBox}">
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="MaxWidth" Value="200" />
        </Style>
        <Style x:Key="Listbox_MP" TargetType="{x:Type ListBox}">
            <Setter Property="BorderBrush" Value="LightGray" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="15" />
        </Style>

    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.Row="0"
            Grid.ColumnSpan="3"
            Margin="0,10,0,0"
            Style="{StaticResource Style_Textblock_Titel_Unter2}"
            Text="Kalenderwochen importieren" />

        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <MD:Card Grid.Row="0" Style="{StaticResource MDCard_Master_Padding}">

                <Border Style="{StaticResource Border_Import_Files}">
                    <ScrollViewer components:DropFilesBehaviorExtension.IsEnabled="True" Style="{StaticResource Scrollviewer_Import_Files}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock
                                FontWeight="Bold"
                                Style="{StaticResource textblock_base}"
                                Text="Ziehen Sie die pdf-Dateien für die betroffene Woche aus dem Kanzleipool auf dieses Feld"
                                TextWrapping="WrapWithOverflow" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </MD:Card>
            <Grid Grid.Row="1" Margin="0,30,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--  Importliste  -->
                <MD:Card
                    Grid.Column="0"
                    Style="{StaticResource MDCard_Master_Padding}"
                    Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>
                        <DataGrid Grid.Row="0" ItemsSource="{Binding ImportFileList, UpdateSourceTrigger=PropertyChanged}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="*" MinWidth="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,30,0"
                                                    Text="{Binding FileName}"
                                                    TextAlignment="Left" />
                                                <!--  Delete  -->
                                                <Button
                                                    x:Name="Btn_Bin_KW"
                                                    Command="{Binding Path=DataContext.MPWeekDeleteCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                    Style="{StaticResource Button_MP_View_RowButton}"
                                                    ToolTip="Löschen der Datei"
                                                    Visibility="Hidden">
                                                    <MD:PackIcon Padding="0" Kind="Bin" />
                                                </Button>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridCell}}, Path=IsSelected}" Value="true">
                                                    <Setter TargetName="Btn_Bin_KW" Property="UIElement.Visibility" Value="{Binding Path=DataContext.ShowAdmin, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridColumn.Header>
                                        Test
                                        <!--<TextBlock Style="{StaticResource Style_ListView_Header}" Text="Dateiname" />-->
                                    </DataGridColumn.Header>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="*" MinWidth="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                Margin="0,-8,0,0"
                                                IsChecked="{Binding WordFileExist}"
                                                IsEnabled="False" />
                                            <!--<TextBlock
                                            Margin="0,0,30,0"
                                            Text="{Binding WordFileExist}"
                                            TextAlignment="Left" />-->
                                            <!--  Delete  -->
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridColumn.Header>
                                        Test
                                        <!--<TextBlock Style="{StaticResource Style_ListView_Header}" Text="Dateiname" />-->
                                    </DataGridColumn.Header>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource Textblock_MPImport_Text}"
                            Text="{Binding AnzahlImportDateien}" />

                        <Button
                            Grid.Row="2"
                            MinWidth="100"
                            MaxWidth="160"
                            Command="{Binding ClearCommand}"
                            Content="Liste leeren"
                            Style="{StaticResource Button_Master}" />

                    </Grid>
                </MD:Card>
                <!--  Settings  -->
                <MD:Card
                    Grid.Column="2"
                    Style="{StaticResource MDCard_Master_Padding}"
                    Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                    <Grid x:Name="Grid_Settings">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>
                        <ScrollViewer
                            Grid.Row="0"
                            Height="{Binding ElementName=Grid_Settings, Path=ActualHeight}"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel Grid.Row="0">
                                <!--  Importeinstellungen  -->
                                <TextBlock Style="{StaticResource Textblock_MPImport_Header}" Text="Importeinstellungen" />
                                <StackPanel
                                    Margin="0,15,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                    <ComboBox
                                        MD:HintAssist.Hint="Kalenderwoche:"
                                        ItemsSource="{Binding KalenderwochenList}"
                                        SelectedIndex="{Binding SelectedKWIndex}"
                                        SelectedItem="{Binding SelectedKW}"
                                        Style="{StaticResource Comobox_MPImport}" />
                                    <ComboBox
                                        MD:HintAssist.Hint="Jahr:"
                                        ItemsSource="{Binding VintageList}"
                                        SelectedIndex="0"
                                        SelectedItem="{Binding SelectedVintage}"
                                        Style="{StaticResource Comobox_MPImport}" />
                                </StackPanel>
                                <Border Margin="0,20,0,0" Style="{StaticResource Expander_Border}" />
                                <!--  EMail-Word-Recipients  -->
                                <!--<StackPanel>
                                    <TextBlock Style="{StaticResource Textblock_MPImport_Header}" Text="Empfänger EMail mit Word-Dateien" />
                                    <ListBox
                                        DisplayMemberPath="MPEMailRecipientAdress"
                                        ItemsSource="{Binding EMailWordList}"
                                        SelectedItem="{Binding SelectedEMailWordRecipient}"
                                        Style="{StaticResource Listbox_MP}" />
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            MD:HintAssist.Hint="EMail-Empfänger:"
                                            Style="{StaticResource Textbox_MP_Import}"
                                            Text="{Binding EMailWordRecipient, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Command="{Binding EMailWordAddCommand}"
                                            CommandParameter="word"
                                            Content="Hinzufügen"
                                            Style="{StaticResource Button_MP_Import}" />
                                        <Button
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Command="{Binding EMailWordDeleteCommand}"
                                            CommandParameter="word"
                                            Content="Löschen"
                                            Style="{StaticResource Button_MP_Import}" />
                                    </Grid>
                                </StackPanel>-->
                                <Border Margin="0,20,0,0" Style="{StaticResource Expander_Border}" />
                                <!--  EMail-pdf-Recipient  -->
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Textblock_MPImport_Header}" Text="Empfänger EMail mit pdf-Dateien" />
                                    <ListBox
                                        DisplayMemberPath="MPEMailRecipientAdress"
                                        ItemsSource="{Binding EMailPDFList}"
                                        SelectedItem="{Binding SelectedEMailpdfRecipient}"
                                        Style="{StaticResource Listbox_MP}" />
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            MD:HintAssist.Hint="EMail-Empfänger:"
                                            Style="{StaticResource Textbox_MP_Import}"
                                            Text="{Binding EMailpdfRecipient, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Command="{Binding EMailpdfAddCommand}"
                                            CommandParameter="pdf"
                                            Content="Hinzufügen"
                                            Style="{StaticResource Button_MP_Import}" />
                                        <Button
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Command="{Binding EMailpdfDeleteCommand}"
                                            CommandParameter="pdf"
                                            Content="Löschen"
                                            Style="{StaticResource Button_MP_Import}" />
                                    </Grid>
                                </StackPanel>
                                <Border Margin="0,20,0,0" Style="{StaticResource Expander_Border}" />
                            </StackPanel>
                        </ScrollViewer>
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                            <StackPanel Height="36" Orientation="Horizontal">
                                <TextBlock
                                    Height="25"
                                    Margin="0,6,10,0"
                                    Style="{StaticResource textblock_base}"
                                    Text="Übertragung auf den BSCW-Server?" />
                                <MW:ToggleSwitch
                                    Grid.Column="1"
                                    Width="100"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    IsOn="{Binding BSCWSubmit}"
                                    OffContent="Nein"
                                    OnContent="Ja"
                                    Style="{StaticResource ToggleSwitchMaster}" />

                            </StackPanel>
                            <ComboBox
                                MaxWidth="150"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                MD:HintAssist.Hint="Laufwerk BSCW-Server:"
                                ItemsSource="{Binding}"
                                SelectedItem="{Binding SelectedDrive}"
                                Style="{StaticResource Combobox_Base}"
                                TextBlock.TextAlignment="Center" />
                        </StackPanel>
                        <Border
                            Grid.Row="2"
                            Margin="0,10,0,10"
                            Style="{StaticResource Expander_Border}" />

                        <Button
                            Grid.Row="3"
                            MinWidth="100"
                            MaxWidth="200"
                            Command="{Binding ImportCommand}"
                            Content="Unterlagen importieren"
                            Style="{StaticResource Button_Master}" />
                    </Grid>
                </MD:Card>
                <!--  Importresult  -->
                <MD:Card
                    Grid.Column="0"
                    Style="{StaticResource MDCard_Master_Padding}"
                    Visibility="{Binding ShowImportResult, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="37*" />
                            <ColumnDefinition Width="376*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                            <TextBlock Style="{StaticResource Textblock_MPImport_Header}" Text="Stand des Importvorgangs" />
                            <TextBlock Style="{StaticResource Textblock_MPImpor_Under}" Text="{Binding ReadMPState, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <Border
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="5,20,4,0"
                            Style="{StaticResource Expander_Border}" />
                        <StackPanel
                            Grid.Row="1"
                            Grid.RowSpan="2"
                            Grid.ColumnSpan="2"
                            Margin="0,21,0,0">
                            <TextBlock Style="{StaticResource Textblock_MPImport_Header}" Text="Importierte Dateien" />

                            <DataGrid Margin="5,15,5,0" ItemsSource="{Binding ImportResultList, UpdateSourceTrigger=PropertyChanged}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="*" MinWidth="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="0,0,30,0"
                                                    Text="{Binding Name}"
                                                    TextAlignment="Left" />
                                                <!--  Delete  -->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridColumn.Header>
                                            Test
                                            <!--<TextBlock Style="{StaticResource Style_ListView_Header}" Text="Dateiname" />-->
                                        </DataGridColumn.Header>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    Margin="0,-8,0,0"
                                                    IsChecked="{Binding Importpdf}"
                                                    IsEnabled="False" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridColumn.Header>
                                            Test
                                            <!--<TextBlock Style="{StaticResource Style_ListView_Header}" Text="Dateiname" />-->
                                        </DataGridColumn.Header>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    Margin="0,-8,0,0"
                                                    IsChecked="{Binding ImportWord}"
                                                    IsEnabled="False" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridColumn.Header>
                                            Test
                                            <!--<TextBlock Style="{StaticResource Style_ListView_Header}" Text="Dateiname" />-->
                                        </DataGridColumn.Header>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                        <Button
                            Grid.Row="3"
                            Grid.ColumnSpan="2"
                            MinWidth="100"
                            MaxWidth="160"
                            Margin="0,9,0,9"
                            Command="{Binding NewImportCommand}"
                            Content="Neuer Import"
                            Style="{StaticResource Button_Master}" />
                    </Grid>
                </MD:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
