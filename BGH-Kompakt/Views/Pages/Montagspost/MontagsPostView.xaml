<UserControl
    x:Class="BGH_Kompakt.Views.MontagsPostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:components="clr-namespace:BGH_Kompakt.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:BGH_Kompakt.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="sy"
    xmlns:viewmodel="clr-namespace:BGH_Kompakt.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:MontagsPostViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Language="de-DE"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Button_MP_View_RowButton"
            BasedOn="{StaticResource MaterialDesignFlatButton}"
            TargetType="Button">
            <Setter Property="Width" Value="35" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="5,0,0,5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="textblock_vermerk" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource MaterialDesignFont}" />
        </Style>
        <Style
            x:Key="textblock_vermerk_bigFont"
            BasedOn="{StaticResource textblock_vermerk}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
        </Style>
        <Style
            x:Key="textblock_vermerk_smallFont"
            BasedOn="{StaticResource textblock_vermerk}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="10,20,0,10" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style
            x:Key="Button_MontagspostView"
            BasedOn="{StaticResource Button_Master}"
            TargetType="{x:Type Button}">
            <Setter Property="MaxWidth" Value="220" />
        </Style>
        <Style
            x:Key="Expander_Border_Vertical_MP"
            BasedOn="{StaticResource Expander_Border_Vertical}"
            TargetType="Border">
            <Setter Property="Margin" Value="0,0,20,0" />
        </Style>
        <Style x:Key="Option_Grid" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
        <Style
            x:Key="Borderline_Options"
            BasedOn="{StaticResource Expander_Border}"
            TargetType="Border">
            <Setter Property="Margin" Value="0,0,20,10" />
        </Style>
    </UserControl.Resources>
    <Grid Background="{StaticResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Style="{StaticResource Style_Textblock_Titel}"
            Text="Montagspost" />
        <MD:Card
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Margin="10,10,0,0"
                    HorizontalAlignment="Left"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,20,0"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="16"
                        FontWeight="Medium"
                        Text="Jahrgang:"
                        TextAlignment="Center" />
                    <ComboBox
                        x:Name="Cbo_Jahr"
                        Margin="0,10,0,0"
                        Padding="5,0,0,0"
                        HorizontalContentAlignment="Left"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="16"
                        ItemsSource="{Binding VintageList}"
                        SelectedItem="{Binding SelectedVintage, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <Border Grid.Column="1" Style="{StaticResource Expander_Border_Vertical_MP}" />
                <!--#region Optionen-->
                <Grid Grid.Column="2" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!--#region Gliederung-->
                    <Grid Grid.Row="0" Style="{StaticResource Option_Grid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{StaticResource Style_Textblock_Montagspost_Lable}"
                            Text="Gliederung:" />
                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton
                                Content="Nach Senaten"
                                IsChecked="{Binding SelectedOutlineSenate, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}" />
                            <RadioButton
                                Content="Alle Entscheidungen"
                                IsChecked="{Binding SelectedOutlineAll, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}" />
                        </WrapPanel>
                    </Grid>
                    <Border Grid.Row="1" Style="{StaticResource Borderline_Options}" />
                    <!--#endregion-->
                    <!--#region Bereiche-->
                    <Grid
                        Grid.Row="2"
                        Style="{StaticResource Option_Grid}"
                        Visibility="{Binding ShowBereiche, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource Style_Textblock_Montagspost_Lable}"
                            Text="Bereich:" />
                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton
                                Content="Zivilsenate"
                                IsChecked="{Binding ShowSelectedZivilsenate, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}"
                                Visibility="{Binding ShowZivilsenate, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVisConverter}}" />
                            <RadioButton
                                Content="Strafsenate"
                                IsChecked="{Binding ShowSelectedStrafsenate, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}"
                                Visibility="{Binding ShowStrafsenate, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVisConverter}}" />
                            <RadioButton
                                Content="Sondersenate"
                                IsChecked="{Binding ShowSelectedSondersenate, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}"
                                Visibility="{Binding ShowSondersenate, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVisConverter}}" />
                            <RadioButton
                                Content="Alle"
                                IsChecked="{Binding ShowSelectedAlleSenate, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}" />
                        </WrapPanel>
                    </Grid>
                    <Border
                        Grid.Row="3"
                        Style="{StaticResource Borderline_Options}"
                        Visibility="{Binding ShowBereiche, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                    <!--#endregion-->
                    <!--#region Ansicht-->
                    <Grid Grid.Row="4" Style="{StaticResource Option_Grid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{StaticResource Style_Textblock_Montagspost_Lable}"
                            Text="Ansicht:" />
                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton
                                Content="Liste mit PDF-Vorschau"
                                IsChecked="{Binding ShowSelectedDetailsPdf, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}" />
                            <RadioButton
                                Content="Liste mit Details"
                                IsChecked="{Binding ShowSelectedDetailsData, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}" />
                        </WrapPanel>
                    </Grid>
                    <Border Grid.Row="5" Style="{StaticResource Borderline_Options}" />
                    <!--#endregion-->
                    <!--#region NewRegion-->
                    <Grid Grid.Row="6" Style="{StaticResource Option_Grid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource Style_Textblock_Montagspost_Lable}"
                            Text="Sammlung:" />
                        <WrapPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton
                                Content="Gesamtübersicht"
                                IsChecked="{Binding ShowSelectedDecisionsAll, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}" />
                            <RadioButton
                                Content="Eigene Mappe"
                                IsChecked="{Binding ShowSelectedDecisionsUser, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource RadioButton_Montagspost}" />
                        </WrapPanel>
                    </Grid>
                    <!--#endregion-->
                </Grid>
                <!--#endregion-->
                <Border Grid.Column="3" Style="{StaticResource Expander_Border_Vertical_MP}" />

                <!--#region EMail/BSCW-Server-->
                <Grid
                    Grid.RowSpan="3"
                    Grid.Column="4"
                    VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!--#region E-Mail-Benachrichtigung-->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource textblock_base}"
                                Text="E-Mail Benachrichtigung über neue Kalenderwochen?"
                                TextAlignment="Left"
                                TextWrapping="WrapWithOverflow" />
                            <MW:ToggleSwitch
                                Grid.Column="1"
                                Width="100"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                IsOn="{Binding EMailNotification}"
                                OffContent="Nein"
                                OnContent="Ja"
                                Style="{StaticResource ToggleSwitchMaster}" />
                        </Grid>
                        <Button
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Click="btn_Filter_Click"
                            Content="Filter anpassen"
                            Style="{StaticResource Button_MontagspostView}" />
                    </Grid>
                    <!--#endregion-->
                    <Border
                        Grid.Column="1"
                        Style="{StaticResource Expander_Border_Vertical}"
                        Visibility="{Binding ShowSelectedDecisionsUser, Converter={StaticResource BoolToVisConverter}}" />
                    <!--#region BSCW-Server-->
                    <Grid Grid.Column="2" Visibility="{Binding ShowSelectedDecisionsUser, Converter={StaticResource BoolToVisConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="47" />
                            <RowDefinition Height="AUto" />
                        </Grid.RowDefinitions>
                        <Button
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,20,0,0"
                            Command="{Binding BSCWServerCommand}"
                            Content="Übertragung BSCW-Server"
                            Style="{StaticResource Button_MontagspostView}" />
                        <ComboBox
                            Grid.Row="1"
                            Grid.Column="1"
                            MaxWidth="150"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            MD:HintAssist.Hint="Laufwerk BSCW-Server:"
                            ItemsSource="{Binding Path=DataContext.DriveList, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                            SelectedItem="{Binding SelectedDrive}"
                            Style="{StaticResource Combobox_Base}"
                            TextBlock.TextAlignment="Center" />
                        <Grid
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Style="{StaticResource textblock_base}"
                                Text="Unterordner anlegen?"
                                TextAlignment="Left"
                                TextWrapping="WrapWithOverflow" />
                            <MW:ToggleSwitch
                                Grid.Column="1"
                                Width="100"
                                Margin="0,0,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                IsOn="{Binding MPBSCWSubFolders}"
                                OffContent="Nein"
                                OnContent="Ja"
                                Style="{StaticResource ToggleSwitchMaster}" />
                        </Grid>


                    </Grid>
                    <!--#endregion-->
                </Grid>
                <!--#endregion-->
            </Grid>
        </MD:Card>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1.6*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <!--#region Kalenderwochen-->
            <MD:Card Grid.Column="0" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,10"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <RadioButton
                            Content="Aufsteigend"
                            IsChecked="{Binding MPSortingAsc}"
                            Style="{StaticResource RadioButton_Base}" />
                        <RadioButton
                            Margin="10,0,0,0"
                            Content="Absteigend"
                            IsChecked="{Binding MPSortingDesc}"
                            Style="{StaticResource RadioButton_Base}" />
                    </StackPanel>
                    <Border
                        Grid.Row="1"
                        BorderBrush="LightGray"
                        BorderThickness="1"
                        Style="{StaticResource Expander_Border}" />
                    <DataGrid
                        Grid.Row="2"
                        Margin="5,5,5,5"
                        HorizontalScrollBarVisibility="Disabled"
                        ItemsSource="{Binding MPWeekList, UpdateSourceTrigger=PropertyChanged}"
                        SelectedIndex="{Binding SelectedMPWeekIndex, UpdateSourceTrigger=PropertyChanged}"
                        SelectedItem="{Binding SelectedMPWeek, UpdateSourceTrigger=PropertyChanged}"
                        SelectionMode="Single"
                        VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                x:Name="Txt_Unterlagen"
                                                Width="80"
                                                Margin="0,0,30,0"
                                                Text="{Binding MPWeekName}"
                                                TextAlignment="Left" />
                                            <!--  Delete  -->
                                            <Button
                                                x:Name="Btn_Bin_KW"
                                                Command="{Binding Path=DataContext.MPWeekDeleteCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                Style="{StaticResource Button_MP_View_RowButton}"
                                                Visibility="Hidden">
                                                <MD:PackIcon Padding="0" Kind="Bin" />
                                            </Button>
                                            <Button
                                                x:Name="Btn_Edit_KW"
                                                Command="{Binding Path=DataContext.MPWeekEditCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                Style="{StaticResource Button_MP_View_RowButton}"
                                                Visibility="Hidden">
                                                <MD:PackIcon Padding="0" Kind="Edit" />
                                            </Button>
                                            <Button
                                                x:Name="Btn_BE_KW"
                                                Command="{Binding Path=DataContext.BECommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                Style="{StaticResource Button_MP_View_RowButton}"
                                                Visibility="Hidden">
                                                <MD:PackIcon Padding="0" Kind="Person" />
                                            </Button>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridCell}}, Path=IsSelected}" Value="true">
                                                <Setter TargetName="Btn_Bin_KW" Property="UIElement.Visibility" Value="{Binding Path=DataContext.ShowAdmin, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                <Setter TargetName="Btn_Edit_KW" Property="UIElement.Visibility" Value="{Binding Path=DataContext.ShowAdmin, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                <Setter TargetName="Btn_BE_KW" Property="UIElement.Visibility" Value="{Binding Path=DataContext.ShowAdmin, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridColumn.Header>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Kalenderwoche" />
                                        <!--<Button
                                                    x:Name="Add_KW"
                                                    Width="50"
                                                    Height="25"
                                                    Margin="10,0,0,0"
                                                    components:FileDragDropHelper.FileDragDropTarget="{Binding}"
                                                    components:FileDragDropHelper.IsFileDragDropEnabled="True"
                                                    AllowDrop="True"
                                                    Background="White"
                                                    BorderThickness="0">
                                                    <MD:PackIcon Kind="Add" />
                                                </Button>-->
                                    </StackPanel>
                                </DataGridColumn.Header>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border
                        Grid.Row="3"
                        Width="155"
                        Height="50"
                        Margin="10"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="3"
                        Visibility="{Binding ShowAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Opacity="0.5" ShadowDepth="0" />
                        </Border.Effect>
                        <Button
                            Width="150"
                            Command="{Binding Path=DataContext.AddKWCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                            Style="{StaticResource Style_Button_Listen}">
                            <!--  Test  -->
                            <StackPanel Orientation="Horizontal">
                                <Label
                                    Height="50"
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontFamily="{StaticResource MaterialDesignFont}"
                                    FontSize="13"
                                    Foreground="Black"
                                    IsEnabled="false">
                                    KW hinzufügen
                                </Label>
                                <MD:PackIcon
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Foreground="Black"
                                    Kind="Add" />
                            </StackPanel>
                        </Button>

                    </Border>
                </Grid>
            </MD:Card>
            <!--#endregion-->
            <!--#region Senate-->
            <MD:Card
                Grid.Column="1"
                Margin="5"
                Visibility="{Binding showSenate, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="70" />
                    </Grid.RowDefinitions>
                    <DataGrid
                        Grid.Row="0"
                        Margin="5,5,5,5"
                        HorizontalScrollBarVisibility="Disabled"
                        ItemsSource="{Binding MPSenateList, UpdateSourceTrigger=PropertyChanged}"
                        SelectedIndex="{Binding SelectedMPSenatIndex, UpdateSourceTrigger=PropertyChanged}"
                        SelectedItem="{Binding SelectedMPSenat}"
                        SelectionMode="Single"
                        VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="40" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                x:Name="Txt_Senate"
                                                Grid.Column="0"
                                                Width="Auto"
                                                Text="{Binding MPSenatName}"
                                                TextAlignment="Left" />
                                            <Border
                                                x:Name="Senat_Circle_Border"
                                                Grid.Column="1"
                                                Width="20"
                                                Height="20"
                                                Margin="0,-10,0,0"
                                                Padding="0"
                                                Background="{StaticResource BGH-Color}"
                                                CornerRadius="50">
                                                <TextBlock
                                                    x:Name="Senat_Circle_Text"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource BGHActivityRequestBackground}"
                                                    Text="{Binding MPDecisions.Count}" />
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                <Setter TargetName="Senat_Circle_Border" Property="Background" Value="{StaticResource BGHActivityRequestBackground}" />
                                                <Setter TargetName="Senat_Circle_Text" Property="Foreground" Value="{StaticResource BGH-Color}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridColumn.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Senat" />
                                    </StackPanel>
                                </DataGridColumn.Header>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border
                        x:Name="brd_Sitzungsliste"
                        Grid.Row="1"
                        Width="155"
                        Height="50"
                        Margin="10"
                        Background="White"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="3">
                        <Border.Effect>
                            <DropShadowEffect Opacity="0.5" ShadowDepth="0" />
                        </Border.Effect>
                        <Button
                            x:Name="Btn_Open_Gesamtliste"
                            Width="150"
                            Command="{Binding Path=DataContext.GesamtDateiCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                            Style="{StaticResource Style_Button_Listen}">
                            <!--  Test  -->
                            <StackPanel Orientation="Horizontal">
                                <Label
                                    x:Name="lbl_Gesamtliste"
                                    Height="50"
                                    Margin="5,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontFamily="{StaticResource MaterialDesignFont}"
                                    FontSize="13"
                                    Foreground="Black"
                                    IsEnabled="false">
                                    Gesamt-pdf
                                </Label>
                                <MD:PackIcon
                                    x:Name="Icon_Sitzungsliste_Open"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Foreground="Black"
                                    Kind="OpenInApp" />
                            </StackPanel>
                        </Button>

                    </Border>
                </Grid>
            </MD:Card>
            <!--#endregion-->
            <!--#region Details Data-->
            <MD:Card
                Name="Detail_1"
                Grid.Column="2"
                Margin="5"
                Visibility="{Binding ShowDetailsPdf, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                <DataGrid
                    Grid.Row="0"
                    Margin="5,5,5,5"
                    HorizontalScrollBarVisibility="Disabled"
                    ItemsSource="{Binding MPDecisionList, UpdateSourceTrigger=PropertyChanged}"
                    SelectedIndex="{Binding SelectedMPDecisionIndex, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    SelectedItem="{Binding SelectedMPDecision, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    SelectionMode="Single"
                    VerticalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="*" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            x:Name="Txt_Entscheidungen"
                                            MinWidth="100"
                                            Margin="0,0,20,0"
                                            Text="{Binding Aktenzeichen}"
                                            TextAlignment="Left" />
                                        <Button
                                            x:Name="Btn_Open"
                                            Command="{Binding Path=DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            Style="{StaticResource Button_MP_View_RowButton}"
                                            ToolTip="Entscheidung öffnen"
                                            Visibility="Hidden">
                                            <MD:PackIcon Padding="0" Kind="OpenInApp" />
                                        </Button>
                                        <Button
                                            x:Name="Btn_Ablage"
                                            Command="{Binding Path=DataContext.OwnerStageCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            CommandParameter="Add"
                                            Style="{StaticResource Button_MP_View_RowButton}"
                                            ToolTip="Entscheidung in die eigene Mappe legen"
                                            Visibility="Hidden">
                                            <MD:PackIcon Padding="0" Kind="Download" />
                                        </Button>
                                        <Button
                                            x:Name="Btn_Bin"
                                            Command="{Binding Path=DataContext.OwnerStageCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            CommandParameter="Remove"
                                            Style="{StaticResource Button_MP_View_RowButton}"
                                            ToolTip="Entscheidung aus der eigenen Mappe entfernen"
                                            Visibility="Hidden">
                                            <MD:PackIcon Padding="0" Kind="Bin" />
                                        </Button>
                                        <Button
                                            x:Name="Btn_Vermerk"
                                            Command="{Binding Path=DataContext.VermerkCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                            Style="{StaticResource Button_MP_View_RowButton}"
                                            ToolTip="Vermerk eingetragen"
                                            Visibility="Hidden">
                                            <MD:PackIcon Padding="0" Kind="NoteEditOutline" />
                                        </Button>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridCell}}, Path=IsSelected}" Value="true">
                                            <Setter TargetName="Btn_Open" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="Btn_Ablage" Property="Visibility" Value="{Binding Path=DataContext.ShowSelectedDecisionsAll, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                            <Setter TargetName="Btn_Bin" Property="Visibility" Value="{Binding Path=DataContext.ShowSelectedDecisionsUser, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                            <Setter TargetName="Btn_Vermerk" Property="Visibility" Value="{Binding Path=DataContext.ShowAdmin, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                            <DataGridColumn.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Entscheidungen" />
                                </StackPanel>
                            </DataGridColumn.Header>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="Auto" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border
                                Margin="20,5,5,25"
                                Padding="5"
                                Background="WhiteSmoke"
                                CornerRadius="5">
                                <StackPanel Orientation="Vertical">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Datum: " />
                                        <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat=d}" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Art: " />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding TypAnzeige}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Normen: " />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Normenkette}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid Visibility="{Binding Path=DataContext.ShowBE, Converter={StaticResource BoolToVisConverter}, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="BE: " />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding BE.MPBEName}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid x:Name="Grid_Vermerk" Visibility="Visible">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Vermerk: " />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Vermerk, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding VermerkVorhanden, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Value="False">
                                    <Setter TargetName="Grid_Vermerk" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDoubleClick">
                            <i:InvokeCommandAction
                                Command="{Binding Path=DataContext.DetailDoubleClickCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                CommandParameter="PDF"
                                PassEventArgsToCommand="True" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </DataGrid>
            </MD:Card>
            <!--#endregion-->
            <!--#region Details pdf-->
            <MD:Card
                Name="Detail_2"
                Grid.Column="2"
                Grid.ColumnSpan="2"
                Margin="5"
                Visibility="{Binding ShowDetailsData, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                <!--<TextBlock TextWrapping="WrapWithOverflow" MaxWidth="{Binding Width, RelativeSource={RelativeSource AncestorType={x:Type MD:Card}, Mode=FindAncestor}}" Text="Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet.     Duis autem vel eum iriure dolor in hendrerit in vulputate velit esse molestie consequat, vel illum dolore eu feugiat nulla facilisis at vero eros et accumsan et iusto odio dignissim qui blandit praesent luptatum zzril delenit augue duis dolore te feugait nulla facilisi. Lorem ipsum dolor sit amet," />-->

                <DataGrid
                    x:Name="DataGridDetail"
                    Grid.Row="0"
                    Margin="5,0,5,5"
                    CellStyle="{StaticResource DataGridCell_Tite}"
                    HorizontalScrollBarVisibility="Auto"
                    ItemsSource="{Binding MPDecisionList, UpdateSourceTrigger=PropertyChanged}"
                    SelectedIndex="{Binding SelectedMPDecisionIndex, UpdateSourceTrigger=PropertyChanged}"
                    SelectedItem="{Binding SelectedMPDecision, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    SelectedValue=""
                    SelectionMode="Single"
                    Style="{StaticResource DataGrid_Tite}"
                    VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Background="AliceBlue"
                                        BorderBrush="LightSlateGray"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                        <Grid Margin="10,10,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock FontWeight="Bold" Text="{Binding Aktenzeichen}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <Button
                                                        Width="35"
                                                        Height="22"
                                                        Margin="10,10,0,0"
                                                        Padding="0"
                                                        HorizontalAlignment="Left"
                                                        Background="White"
                                                        BorderThickness="0"
                                                        Command="{Binding Path=DataContext.OwnerStageCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="Add"
                                                        ToolTip="Entscheidung in die persönliche Ablage kopieren"
                                                        Visibility="{Binding Path=DataContext.ShowSelectedDecisionsAll, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                        <MD:PackIcon Padding="0" Kind="Download" />
                                                    </Button>
                                                    <Button
                                                        Width="35"
                                                        Height="22"
                                                        Margin="10,10,0,0"
                                                        Padding="0"
                                                        HorizontalAlignment="Left"
                                                        Background="White"
                                                        BorderThickness="0"
                                                        Command="{Binding Path=DataContext.OwnerStageCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                        CommandParameter="Remove"
                                                        ToolTip="Entscheidung aus der persönlichen Ablage entfernen"
                                                        Visibility="{Binding Path=DataContext.ShowSelectedDecisionsUser, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                        <MD:PackIcon Padding="0" Kind="Bin" />
                                                    </Button>
                                                    <Button
                                                        x:Name="Btn_Open"
                                                        Width="35"
                                                        Height="22"
                                                        Margin="10,10,0,0"
                                                        Padding="0"
                                                        HorizontalAlignment="Left"
                                                        Background="White"
                                                        BorderThickness="0"
                                                        Command="{Binding Path=DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                        ToolTip="Entscheidung öffnen"
                                                        Visibility="Collapsed">
                                                        <MD:PackIcon Padding="0" Kind="OpenInApp" />
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="15,0">
                                                <TextBlock HorizontalAlignment="Left" Text="{Binding Date, StringFormat=d}" />
                                                <TextBlock
                                                    MaxWidth="230"
                                                    HorizontalAlignment="Left"
                                                    Text="{Binding TypAnzeige}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    MaxWidth="230"
                                                    HorizontalAlignment="Left"
                                                    Text="{Binding Normenkette}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    MaxWidth="230"
                                                    HorizontalAlignment="Left"
                                                    Text="{Binding BE.MPBEName}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    MaxWidth="230"
                                                    HorizontalAlignment="Left"
                                                    Text="{Binding Vermerk, UpdateSourceTrigger=PropertyChanged}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="2"
                                                Width="Auto"
                                                MaxWidth="700"
                                                Padding="0,0,10,0"
                                                Text="{Binding Leitsatz}"
                                                TextWrapping="Wrap" />
                                        </Grid>
                                        <Border.Effect>
                                            <DropShadowEffect Opacity="0.2" />
                                        </Border.Effect>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridCell}}, Path=IsSelected}" Value="true">
                                            <Setter TargetName="Btn_Open" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                            <DataGridColumn.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Style_ListView_Header}" Text="Entscheidungen" />
                                </StackPanel>
                            </DataGridColumn.Header>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="Auto" />
                        </Style>
                    </DataGrid.RowStyle>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDoubleClick">
                            <i:InvokeCommandAction
                                Command="{Binding Path=DataContext.DetailDoubleClickCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                CommandParameter="List"
                                PassEventArgsToCommand="True" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </DataGrid>
            </MD:Card>
            <!--#endregion-->
            <!--#region Vorschau-->
            <MD:Card
                Grid.Column="3"
                Margin="5"
                Visibility="{Binding ShowWebbrowser, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}">
                <Grid>
                    <WebBrowser
                        Margin="10"
                        components:WebBrowserUtility.BindableSource="{Binding URLAdress, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding ShowWebbrowserData, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Visibility="{Binding ShowWebbrowserVermerk, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                        <Image
                            Width="70"
                            Margin="0,25"
                            Source="/Resources/ImageResources/Images/Bundesadler.png" />
                        <TextBlock Style="{StaticResource textblock_vermerk_bigFont}" Text="DOKUMENTATIONSSTELLE" />
                        <TextBlock Style="{StaticResource textblock_vermerk_bigFont}" Text="DES" />
                        <TextBlock Style="{StaticResource textblock_vermerk_bigFont}" Text="BUNDESGERICHTSHOFS" />
                        <TextBlock Style="{StaticResource textblock_vermerk_smallFont}" Text="Die Entscheidung kann aus folgendem Grund nicht mehr eingesehen werden:" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource textblock_vermerk_smallFont}"
                            Text="{Binding Vermerktext, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </MD:Card>
            <!--#endregion-->
        </Grid>
    </Grid>
</UserControl>
