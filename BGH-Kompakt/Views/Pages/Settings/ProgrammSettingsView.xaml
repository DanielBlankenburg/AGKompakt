<UserControl
    x:Class="BGH_Kompakt.Views.Settings.ProgrammSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:systemsettings="clr-namespace:BGH_Kompakt.ViewModel.SystemSettings"
    d:DataContext="{d:DesignInstance Type=systemsettings:ProgrammSettingViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Button_ProgrammSettings"
            BasedOn="{StaticResource Button_Master}"
            TargetType="{x:Type Button}">
            <Setter Property="MaxWidth" Value="200" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
        <Style
            x:Key="Border_Programmsettings"
            BasedOn="{StaticResource Expander_Border}"
            TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="10,15" />
        </Style>
        <Style
            x:Key="Label_Programmsettings"
            BasedOn="{StaticResource Label_Base}"
            TargetType="{x:Type Label}">
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style
            x:Key="Textbox_Programmsettings"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="{x:Type TextBox}">
            <Setter Property="MinWidth" Value="300" />
            <Setter Property="MaxWidth" Value="400" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>
        <Style x:Key="ToggleSwitchFilter_Anzeige" TargetType="{x:Type MW:ToggleSwitch}">
            <Setter Property="OffContent" Value="Aus" />
            <Setter Property="OnContent" Value="An" />
            <!--<Setter Property="Margin" Value="0,0,10,0" />-->
        </Style>
        <Style
            x:Key="Label_ToggleSwitch"
            BasedOn="{StaticResource Label_Base}"
            TargetType="Label">
            <Setter Property="Margin" Value="10,10,0,0" />
        </Style>

    </UserControl.Resources>
    <Grid Background="{StaticResource MaterialDesignPaper}">
        <MD:Card
            Grid.Column="0"
            Margin="20,10,20,10"
            Padding="10">
            <StackPanel VerticalAlignment="Top" Orientation="Vertical">
                <Button
                    Command="{Binding SeedAZCommand}"
                    Content="Seed AZ"
                    Style="{StaticResource Button_ProgrammSettings}" />
                <Button
                    Command="{Binding SeedARCommand}"
                    Content="Seed AR"
                    Style="{StaticResource Button_ProgrammSettings}" />
                <Button
                    Command="{Binding SeedMontagspostCommand}"
                    Content="Seed Montagspost"
                    Style="{StaticResource Button_ProgrammSettings}" />
                <Button
                    Command="{Binding SeedDienstbezeichnungen}"
                    Content="Seed Dienstbezeichnungen"
                    Style="{StaticResource Button_ProgrammSettings}" />
                <Border Style="{StaticResource Border_Programmsettings}" />
                <StackPanel DataContext="{Binding ProgrammSetting}">
                    <TextBox
                        MD:HintAssist.Hint="Pfad Sitzungsunterlagen:"
                        Style="{StaticResource Textbox_Programmsettings}"
                        Text="{Binding PathSitzungsunterlagen}" />
                    <TextBox
                        MD:HintAssist.Hint="Pfad Unterlagenverwaltung:"
                        Style="{StaticResource Textbox_Programmsettings}"
                        Text="{Binding Pathunterlagenverwaltung}" />
                    <TextBox
                        MD:HintAssist.Hint="Pfad Montagspost:"
                        Style="{StaticResource Textbox_Programmsettings}"
                        Text="{Binding PathMontagspost}" />
                    <TextBox
                        MD:HintAssist.Hint="Pfad Dokstelle:"
                        Style="{StaticResource Textbox_Programmsettings}"
                        Text="{Binding PathDokstelle}" />
                    <TextBox
                        MD:HintAssist.Hint="Pfad DokstelleDFS:"
                        Style="{StaticResource Textbox_Programmsettings}"
                        Text="{Binding PathDokstelleDFS}" />
                    <TextBox
                        MD:HintAssist.Hint="Pfad E-Mail-Dokstelle:"
                        Style="{StaticResource Textbox_Programmsettings}"
                        Text="{Binding EMailDokstelle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Margin="0,15,0,15"
                        Command="{Binding TestPath}"
                        Content="Test Pfad Dfs+Dokstelle"
                        Style="{StaticResource Button_ProgrammSettings}" />
                    <Border Style="{StaticResource Border_Programmsettings}" />
                    <Button
                        Margin="0,15,0,15"
                        Command="{Binding SaveSettings}"
                        Content="Änderungen speichern"
                        Style="{StaticResource Button_ProgrammSettings}" />
                    <Border Style="{StaticResource Border_Programmsettings}" />
                </StackPanel>
                <Border Style="{StaticResource Border_Programmsettings}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        Content="Anzeige Montagspost"
                        Style="{StaticResource Label_ToggleSwitch}" />
                    <MW:ToggleSwitch
                        Grid.Row="0"
                        Grid.Column="1"
                        IsOn="{Binding AnzeigeMontagspost, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource ToggleSwitchFilter_Anzeige}" />
                    <Label
                        Grid.Row="1"
                        Grid.Column="0"
                        Content="Anzeige Nebetätigkeiten"
                        Style="{StaticResource Label_ToggleSwitch}" />
                    <MW:ToggleSwitch
                        Grid.Row="1"
                        Grid.Column="1"
                        IsOn="{Binding AnzeigeActivitRequests, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource ToggleSwitchFilter_Anzeige}" />


                </Grid>
            </StackPanel>
        </MD:Card>

    </Grid>

</UserControl>
