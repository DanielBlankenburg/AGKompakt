<UserControl
    x:Class="BGH_Kompakt.Views.Kanzleiunterlagen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Background="{StaticResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Margin="267,10,0,0"
            HorizontalAlignment="Left"
            FontSize="30"
            FontWeight="ExtraBlack"
            Text="Kanzleiunterlagen"
            TextAlignment="Center" />
        <Border
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Height="50"
            Margin="3,14,3,16"
            BorderThickness="0,0,0,1"
            Style="{StaticResource Style_Border_Color}">
            <MD:Card
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="750"
                Margin="5,0,0,10"
                HorizontalAlignment="Left">
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Height="40"
                    Margin="30,0,0,0"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,10,20,0"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="16"
                        FontWeight="Medium"
                        Text="Bitte wählen einen Bereich aus:"
                        TextAlignment="Center" />
                    <ComboBox
                        x:Name="Cbo_RegZ"
                        Width="100"
                        HorizontalContentAlignment="Center"
                        DisplayMemberPath="Item_Name"
                        DropDownClosed="Cbo_RegZ_DropDownClosed"
                        FontFamily="{StaticResource MaterialDesignFont}"
                        FontSize="16"
                        SelectedValue="Name" />
                </StackPanel>
            </MD:Card>
        </Border>
    </Grid>
</UserControl>
