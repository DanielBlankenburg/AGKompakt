<UserControl
    x:Class="BGH_Kompakt.Views.Pages.TestDesign.StartTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.TestDesign"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="ButtonMainwindow"
            BasedOn="{StaticResource MahApps.Styles.Button}"
            TargetType="{x:Type Button}">
            <Setter Property="Width" Value="300" />
            <Setter Property="Height" Value="280" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0,10,20,20" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <!--<Setter Property="Height" Value="250" />-->
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Height"
                                    To="350"
                                    Duration="0:0:0.300" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Height"
                                    To="280"
                                    Duration="0:0:0.300" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ButtonMainwindowButtonBorder" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Height" Value="380" />
            <Setter Property="Width" Value="320" />
        </Style>
        <Style x:Key="ButtonMainwindowImageBorder" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Height" Value="200" />
            <Setter Property="Width" Value="250" />
        </Style>
        <Style
            x:Key="ButtonMainwindowInformationBorder"
            BasedOn="{StaticResource MahApps.Styles.Button.Circle}"
            TargetType="{x:Type Button}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <!--<Style
            x:Key="ButtonMainwindowPackIcon"
            TargetType="{x:Type MD:PackIcon}">
            <Setter Property="Height" Value="25" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray3}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>-->
    </UserControl.Resources>
    <Grid Background="{StaticResource MaterialDesignPaper}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <WrapPanel>
            <Button
                x:Name="Btn_Main_Sitzungsunterlagen"
                Style="{StaticResource Button_Mainwindow}"
                Visibility="{Binding ShowSitzungsunterlagen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                <StackPanel>
                    <Image Source="/Resources/ImageResources/Images/Unterlagen.jpg" Style="{StaticResource Button_Mainwindow_Image}" />
                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Sitzungsunterlagen" />
                </StackPanel>
            </Button>
            <Button
                x:Name="Btn_Main_Sitzungsunterlagen2"
                Style="{StaticResource Button_Mainwindow}"
                Visibility="{Binding ShowSitzungsunterlagen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                <StackPanel>
                    <Image Source="/Resources/ImageResources/Images/Nebentaetigkeiten.png" Style="{StaticResource Button_Mainwindow_Image}" />
                    <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Sitzungsunterlagen" />
                </StackPanel>
            </Button>
        </WrapPanel>
        <WrapPanel Grid.Column="1">
            <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                <Button
                    x:Name="Btn_Test"
                    Style="{StaticResource ButtonMainwindow}"
                    Visibility="{Binding ShowSitzungsunterlagen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                    <StackPanel VerticalAlignment="Top">
                        <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                            <Border.Background>
                                <ImageBrush ImageSource="/Resources/ImageResources/Images/Unterlagen.jpg" Stretch="Fill" />
                            </Border.Background>
                        </Border>
                        <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Sitzungsunterlagen" />
                        <Button x:Name="Info_Test" Style="{StaticResource ButtonMainwindowInformationBorder}">
                            <MD:PackIcon
                                Width="25"
                                Height="25"
                                Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                Kind="InformationCircle" />
                        </Button>

                    </StackPanel>
                </Button>

            </Border>
            <Border Style="{StaticResource ButtonMainwindowButtonBorder}">
                <Button
                    x:Name="Btn_Test2"
                    Style="{StaticResource ButtonMainwindow}"
                    Visibility="{Binding ShowSitzungsunterlagen, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                    <StackPanel VerticalAlignment="Top">
                        <Border Style="{StaticResource ButtonMainwindowImageBorder}">
                            <Border.Background>
                                <ImageBrush ImageSource="/Resources/ImageResources/Images/Nebentaetigkeiten.png" Stretch="Fill" />
                            </Border.Background>
                        </Border>
                        <TextBlock Style="{StaticResource Button_Mainwindow_Textblock}" Text="Nebentätigkeiten" />
                        <Button x:Name="Info_Test2" Style="{StaticResource ButtonMainwindowInformationBorder}">
                            <MD:PackIcon
                                Width="25"
                                Height="25"
                                Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                                Kind="InformationCircle" />
                        </Button>
                    </StackPanel>
                </Button>
            </Border>
        </WrapPanel>
    </Grid>
</UserControl>
