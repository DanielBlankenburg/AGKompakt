                                                        <GridViewColumn
                                                            Width="500"
                                                            DisplayMemberBinding="{Binding FileName}"
                                                            Header="Dateiname"
                                                            HeaderContainerStyle="{StaticResource Person_GridViewColumn}" />
                                                        <GridViewColumn Width="Auto">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Button
                                                                            x:Name="Btn_Open"
                                                                            Command="{Binding Path=DataContext.OpenAttechmentCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                                            Style="{StaticResource Button_GridView}"
                                                                            ToolTip="Anlage öffnen">
                                                                            <MD:PackIcon Padding="0" Kind="File" />
                                                                        </Button>
                                                                        <Button
                                                                            x:Name="Btn_Bin"
