                                Visibility="{Binding ShowClear, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Margin="0,0,10,0"
                                Command="{Binding ApplyCommand}"
                                Content="{Binding SaveLabel}"
                                Style="{StaticResource Button_Master}" />
                            <Button
                                Margin="0,0,10,0"
                                Command="{Binding QuitCommand}"
