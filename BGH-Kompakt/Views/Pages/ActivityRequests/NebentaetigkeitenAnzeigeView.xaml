                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                            <!--<ComboBox
                                    Width="150"
                                    ItemsSource="{Binding Items}"
                                    SelectedItem="{Binding SelectedItem}" />-->
                            <Button
                                Margin="0,0,10,0"
                                Command="{Binding NewCommand}"
