                                                Style="{StaticResource Button_Master}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Margin="0,0,0,15" Style="{StaticResource Expander_Border}" />
                                    <StackPanel Style="{StaticResource Stackpanel_Vertical}">
