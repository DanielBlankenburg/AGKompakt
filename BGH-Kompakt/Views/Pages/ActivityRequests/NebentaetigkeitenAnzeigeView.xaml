                                <Hyperlink>
                                    (§ 99 Abs. 1 BBG
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Click">
                                            <i:InvokeCommandAction Command="{Binding Path=DataContext.HyperLinkCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" CommandParameter="§ 99 BBG" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock
                                xml:space="preserve"
                                Style="{StaticResource Textblock_Hinweistext_Wrappanel}"
                                TextWrapping="WrapWithOverflow"> iVm</TextBlock>
                            <TextBlock Style="{StaticResource Textblock_Hinweistext_Wrappanel}">
                                <Hyperlink>
                                    § 46 DRiG)
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Click">
                                            <i:InvokeCommandAction Command="{Binding Path=DataContext.HyperLinkCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" CommandParameter="§ 46 DRiG" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Hyperlink>
                            </TextBlock>
