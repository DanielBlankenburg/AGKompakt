<UserControl
    x:Class="BGH_Kompakt.Views.NebentaetigkeitenAnzeigeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:System="clr-namespace:System;assembly=mscorlib"
    xmlns:components="clr-namespace:BGH_Kompakt.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:BGH_Kompakt.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:BGH_Kompakt.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:NebentaetigkeitenAnzeigeViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Language="de-DE"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="Combobox_Request"
            BasedOn="{StaticResource Combobox_Base}"
            TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Width" Value="335" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style
            x:Key="Combobox_Request_Client"
            BasedOn="{StaticResource Combobox_Request}"
            TargetType="{x:Type ComboBox}">
            <!--<Setter Property="MD:HintAssist.Hint" Value="{Binding Hint_Client}" />-->
            <Setter Property="ItemsSource" Value="{Binding Path=Clientlist}" />
            <Setter Property="SelectedIndex" Value="0" />
            <Setter Property="SelectedValue" Value="{Binding SelectedClient, Mode=TwoWay}" />
        </Style>

        <Style
            x:Key="Datepicker_Request"
            BasedOn="{StaticResource Datepicker_Base}"
            TargetType="{x:Type DatePicker}">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Width" Value="400" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style
            x:Key="Listbox_Request"
            BasedOn="{StaticResource MaterialDesignFilterChipListBox}"
            TargetType="{x:Type ListBox}" />
        <Style
            x:Key="Checkbox_Request"
            BasedOn="{StaticResource Checkbox_Base}"
            TargetType="{x:Type CheckBox}">
            <Setter Property="Margin" Value="0,5,10,0" />

        </Style>
        <Style
            x:Key="Textbox_Request"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Width" Value="400" />
        </Style>
        <Style
            x:Key="Textbox_Request_large"
            BasedOn="{StaticResource Textbox_Request}"
            TargetType="{x:Type TextBox}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Height" Value="Auto" />
        </Style>
        <!--<Style
            x:Key="Button_Expander"
            BasedOn="{StaticResource MaterialDesignFloatingActionMiniLightButton}"
            TargetType="{x:Type Button}">
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
            <Setter Property="MD:ShadowAssist.ShadowDepth" Value="Depth0" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>-->

        <!--<Style x:Key="Stackpanel_Expander" TargetType="{x:Type StackPanel}">
            <Setter Property="Margin" Value="24,20,24,16" />
            <Setter Property="MinWidth" Value="500" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Orientation" Value="Vertical" />
        </Style>-->

        <Style x:Key="Stackpanel_Vertical" TargetType="{x:Type StackPanel}">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Orientation" Value="Vertical" />
        </Style>
        <Style x:Key="Stackpanel_Vertical_Verguetung" TargetType="{x:Type StackPanel}">
            <Setter Property="Margin" Value="15,0,0,20" />
            <Setter Property="Orientation" Value="Vertical" />
        </Style>
        <Style x:Key="Stackpanel_Horizontal" TargetType="{x:Type StackPanel}">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>

        <Style
            x:Key="Button_Add"
            BasedOn="{StaticResource MaterialDesignRaisedButton}"
            TargetType="{x:Type Button}">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="15,0,0,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style
            x:Key="Button_Add_Client"
            BasedOn="{StaticResource Button_Add}"
            TargetType="{x:Type Button}">
            <Setter Property="ToolTip" Value="Anlegen eines neuen Auftraggebers" />
            <Setter Property="Command" Value="{Binding ClientCommand}" />
        </Style>

        <Style
            x:Key="RadioButto_Verguetung"
            BasedOn="{StaticResource RadioButton_Base}"
            TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
        <Style
            x:Key="ExtenderStackpanelAR"
            BasedOn="{StaticResource Stackpanel_Expander}"
            TargetType="StackPanel">
            <Setter Property="Margin" Value="70,10,24,16" />
        </Style>
        <Style
            x:Key="ExpanderAR"
            BasedOn="{StaticResource MaterialDesignExpander}"
            TargetType="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsExpanded" Value="True">
                    <Setter Property="Background" Value="{StaticResource BGHActivityRequestBackground}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Stackpanel_Anlagen" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Vertical" />
            <Setter Property="Margin" Value="30,10,0,0" />
        </Style>

        <Style
            x:Key="Label_AR"
            BasedOn="{StaticResource Label_Base}"
            TargetType="{x:Type Label}">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style
            x:Key="Label_Verguetung"
            BasedOn="{StaticResource Label_Base}"
            TargetType="{x:Type Label}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
        <Style
            x:Key="Textblock_Hinweistext"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style
            x:Key="Textblock_Hinweistext_List"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="10,5,0,10" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style
            x:Key="Textblock_Hinweistext_Wrappanel"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>
        <Style
            x:Key="Textblock_Hinweistext_Titel"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,10,0,10" />
            <Setter Property="TextWrapping" Value="WrapWithOverflow" />
        </Style>
        <Style
            x:Key="Textblock_Hinweistext_TopTitel"
            BasedOn="{StaticResource textblock_base}"
            TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
        </Style>

    </UserControl.Resources>
    <ScrollViewer MaxHeight="{Binding RelativeSource={RelativeSource AncestorType={x:Type Border}}, Path=ActualHeight}" VerticalScrollBarVisibility="Auto">
        <Grid x:Name="Grid_Main" Background="{StaticResource BGHActivityRequestBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!--#region Formular-->
            <Grid
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!--<TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Left"
                    d:Text="Introduction"
                    Style="{StaticResource Style_Textblock_Eingabefenster}"
                    Text="{Binding Introduction}"
                    TextAlignment="Center" />-->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Visibility="{Binding ShowApplicant, Converter={StaticResource BoolToVisConverter}}">
                    <ComboBox
                        MD:HintAssist.Hint="Antragsteller/in:"
                        ItemsSource="{Binding ApplicantList}"
                        SelectedItem="{Binding ApplicantSelected, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource Combobox_Base}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition MinWidth="150" />
                                        <ColumnDefinition MinWidth="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Fullname}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Text="{Binding Position.PositionText}" />
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button
                        Margin="30,0,0,0"
                        Command="{Binding AddPersonCommand}"
                        Content="Person hinzufügen"
                        Style="{StaticResource Button_Master}" />
                    <Button
                        Margin="30,0,0,0"
                        Command="{Binding AddRequestsCommand}"
                        Content="Masseneintrag"
                        Style="{StaticResource Button_Master}" />
                </StackPanel>
                <Grid
                    Grid.Row="2"
                    Margin="0,5,0,0"
                    Visibility="{Binding ShowActivityRequest, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!--<MD:Card
                                Grid.Column="1"
                                MinWidth="600"
                                Margin="0,30,0,0">-->
                        <StackPanel Grid.Column="1">
                            <!--#region Art-->
                            <Expander
                                x:Name="Details"
                                IsExpanded="{Binding Anzeige_Art, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ExpanderAR}">
                                <Expander.Header>
                                    <TextBlock Style="{StaticResource Textblock_Extender}" Text="Art" />
                                </Expander.Header>
                                <StackPanel Style="{StaticResource ExtenderStackpanelAR}">
                                    <!--#region Meldeart; Visibility: true-->
                                    <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="Anzeigepflichtig" IsChecked="{Binding Anzeigepflichtig}" />
                                            <RadioButton
                                                Margin="10,0,0,0"
                                                Content="Genehmigungspflichtig"
                                                IsChecked="{Binding Genehmigungspflichtig}" />
                                        </StackPanel>
                                        <!--  ErrorValidation  -->
                                        <TextBlock
                                            Style="{StaticResource Style_Textbox_Error}"
                                            Text="Bitte wählen Sie eine Option aus"
                                            Visibility="{Binding ErrorRequestMeldeArt, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <!--#endregion-->
                                    <!--#region Gesamt; Visibility: AnzeigeGesamt-->
                                    <StackPanel
                                        Margin="30,0,0,0"
                                        Orientation="Vertical"
                                        Visibility="{Binding AnzeigeGesamt, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                        <!--#region Auswahl Tätigkeitsart. Visibility: true-->
                                        <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                            <ComboBox
                                                MD:HintAssist.Hint="Tätigkeitsart"
                                                DisplayMemberPath="ActivityRequestTypText"
                                                ItemsSource="{Binding Path=RequestTyplist, UpdateSourceTrigger=PropertyChanged}"
                                                SelectedItem="{Binding SelectedRequestTyp}"
                                                SelectedValue="{Binding SelectedRequestTyp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource Combobox_Request}" />
                                            <!--  ErrorValidation  -->
                                            <TextBlock
                                                Style="{StaticResource Style_Textbox_Error}"
                                                Text="Bitte wählen Sie eine Option aus"
                                                Visibility="{Binding ErrorRequestTyp, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <!--#endregion-->
                                        <!--#region Details, Visibility: AnzeigeDetails-->
                                        <StackPanel Margin="30,0,0,0" Visibility="{Binding AnzeigeDetails, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                            <!--#region Vortragstätigkeit; Visibility: AnzeigeVortragstaetigkeit-->
                                            <StackPanel Visibility="{Binding AnzeigeVortragstaetigkeit, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                <!--  Titel  -->
                                                <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                                    <TextBox
                                                        MD:HintAssist.Hint="{Binding Hint_RequestTitel}"
                                                        Style="{StaticResource Textbox_Request}"
                                                        Text="{Binding RequestTitel}" />
                                                    <!--  ErrorValidation  -->
                                                    <TextBlock
                                                        Style="{StaticResource Style_Textbox_Error}"
                                                        Text="Bitte geben ein Titel ein"
                                                        Visibility="{Binding ErrorTitel, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <!--  Auftraggeber  -->
                                                <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <!--<ComboBox
                                                            ItemsSource="{Binding CollectionView.View}"
                                                            SelectedIndex="{Binding SelectedClientIndex, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectedValue="{Binding SelectedClient}"
                                                            Style="{StaticResource Combobox_Request_Client}"
                                                            TextSearch.TextPath="Name">
                                                            <ComboBox.GroupStyle>
                                                                <GroupStyle>
                                                                    <GroupStyle.HeaderTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock
                                                                                Height="25"
                                                                                Margin="0,5,0,5"
                                                                                Padding="5,5,0,0"
                                                                                VerticalAlignment="Center"
                                                                                FontWeight="Bold"
                                                                                Text="{Binding Name}" />
                                                                        </DataTemplate>
                                                                    </GroupStyle.HeaderTemplate>
                                                                </GroupStyle>
                                                            </ComboBox.GroupStyle>
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Margin="0,0,0,0" Text="{Binding ACName}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>-->
                                                        <ComboBox
                                                            MD:HintAssist.Hint="Veranstalter"
                                                            ItemsSource="{Binding Clientlist}"
                                                            SelectedValue="{Binding SelectedClient}"
                                                            Style="{StaticResource Combobox_Request_Client}"
                                                            TextSearch.TextPath="ACName">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel>
                                                                        <TextBlock
                                                                            Grid.Column="0"
                                                                            Margin="0,0,0,0"
                                                                            Text="{Binding ACName}" />
                                                                        <TextBlock
                                                                            Grid.Column="1"
                                                                            Margin="0,0,0,0"
                                                                            FontSize="10"
                                                                            FontStyle="Italic"
                                                                            Text="{Binding ActivityClientTyp.ActivityClientTypText}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <Button Style="{StaticResource Button_Add_Client}">
                                                            <MD:PackIcon Kind="Add" />
                                                        </Button>
                                                    </StackPanel>
                                                    <!--  ErrorValidation  -->
                                                    <TextBlock
                                                        Style="{StaticResource Style_Textbox_Error}"
                                                        Text="Bitte wählen Sie einen Eintrag aus"
                                                        Visibility="{Binding ErrorClient, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <!--  Ort  -->
                                                <StackPanel Margin="0,10,0,0" Orientation="Vertical">
                                                    <StackPanel Style="{StaticResource Stackpanel_Horizontal}">
                                                        <RadioButton Content="Online" IsChecked="{Binding Online, UpdateSourceTrigger=PropertyChanged}" />
                                                        <RadioButton
                                                            Margin="10,0,0,0"
                                                            Content="Präsenz"
                                                            IsChecked="{Binding Presence, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <!--  ErrorValidation  -->
                                                    <TextBlock
                                                        Style="{StaticResource Style_Textbox_Error}"
                                                        Text="Bitte wählen Sie eine Option aus"
                                                        Visibility="{Binding ErrorOrtArt, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox
                                                        MD:HintAssist.Hint="Ortsbezeichnung"
                                                        Style="{StaticResource Textbox_Request}"
                                                        Text="{Binding RequestOrt}"
                                                        Visibility="{Binding AnzeigeOrt, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                    <!--  ErrorValidation  -->
                                                    <TextBlock
                                                        Style="{StaticResource Style_Textbox_Error}"
                                                        Text="Bitte wählen Sie einen Ort ein"
                                                        Visibility="{Binding ErrorOrt, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <!--  Datum  -->
                                                <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                                    <DatePicker
                                                        MD:HintAssist.Hint="Datum"
                                                        SelectedDate="{Binding RequestDate, UpdateSourceTrigger=PropertyChanged}"
                                                        Style="{StaticResource Datepicker_Request}"
                                                        Text="{Binding RequestDate}" />
                                                    <!--  ErrorValidation  -->
                                                    <TextBlock
                                                        Style="{StaticResource Style_Textbox_Error}"
                                                        Text="Bitte wählen Sie ein Datum aus"
                                                        Visibility="{Binding ErrorDate, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <!--#endregion-->
                                            <!--#region Wissenschaftliche Tätigkeit; Visibility: AnzeigeScience-->
                                            <StackPanel Visibility="{Binding AnzeigeScience, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                <!--#region Art der wissenschaftlichen Tätigkeit-->
                                                <StackPanel Style="{StaticResource Stackpanel_Vertical}" Visibility="{Binding AnzeigeScienceArt, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <RadioButton Content="Wissenschaftliche Veröffentlichung" IsChecked="{Binding Publication, UpdateSourceTrigger=PropertyChanged}" />
                                                        <RadioButton
                                                            Margin="10,0,0,0"
                                                            Content="Lehrtätigkeit"
                                                            IsChecked="{Binding Education, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        Style="{StaticResource Style_Textbox_Error}"
                                                        Text="Bitte wählen Sie eine Option aus"
                                                        Visibility="{Binding ErrorScienceCategory, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <!--#endregion-->
                                                <!--#region Veröffentlichung; Visibility: AnzeigePublication-->
                                                <StackPanel Visibility="{Binding AnzeigePublication, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                    <!--  Art der Veröffentlichung  -->
                                                    <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                                        <ComboBox
                                                            MD:HintAssist.Hint="Art der Veröffentlichung"
                                                            DisplayMemberPath="ActivityRequestScienceTypText"
                                                            ItemsSource="{Binding Path=ScienceTypList}"
                                                            SelectedValue="{Binding SelectedScienceTyp, Mode=TwoWay}"
                                                            Style="{StaticResource Combobox_Request}"
                                                            Visibility="{Binding AnzeigeScienceTyp, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock
                                                            Style="{StaticResource Style_Textbox_Error}"
                                                            Text="Bitte wählen Sie eine Option aus"
                                                            Visibility="{Binding ErrorScienceTyp, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <!--  Titel  -->
                                                    <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                                        <TextBox
                                                            MD:HintAssist.Hint="{Binding Hint_RequestTitel}"
                                                            Style="{StaticResource Textbox_Request}"
                                                            Text="{Binding RequestTitel}" />
                                                        <!--  ErrorValidation  -->
                                                        <TextBlock
                                                            Style="{StaticResource Style_Textbox_Error}"
                                                            Text="Bitte geben ein Thema ein"
                                                            Visibility="{Binding ErrorTitel, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <!--  Auftraggeber  -->
                                                    <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ComboBox
                                                                MD:HintAssist.Hint="Veranstalter"
                                                                ItemsSource="{Binding Clientlist}"
                                                                SelectedValue="{Binding SelectedClient}"
                                                                Style="{StaticResource Combobox_Request_Client}"
                                                                TextSearch.TextPath="ACName">
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel>
                                                                            <TextBlock
                                                                                Grid.Column="0"
                                                                                Margin="0,0,0,0"
                                                                                Text="{Binding ACName}" />
                                                                            <TextBlock
                                                                                Grid.Column="1"
                                                                                Margin="0,0,0,0"
                                                                                FontSize="10"
                                                                                FontStyle="Italic"
                                                                                Text="{Binding ActivityClientTyp.ActivityClientTypText}" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                            <Button Style="{StaticResource Button_Add_Client}">
                                                                <MD:PackIcon Kind="Add" />
                                                            </Button>
                                                        </StackPanel>
                                                        <!--  ErrorValidation  -->
                                                        <TextBlock
                                                            Style="{StaticResource Style_Textbox_Error}"
                                                            Text="Bitte wählen Sie einen Eintrag aus"
                                                            Visibility="{Binding ErrorClient, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <!--  Art der Mitwirkung  -->
                                                    <StackPanel Margin="0,20,0,0" Visibility="{Binding AnzeigeScienceAuthor, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                        <Label Content="Art der Mitwirkung (Mehrfachnennungen sind möglich)" Style="{StaticResource Label_Base}" />
                                                        <ListBox
                                                            Margin="30,10,0,0"
                                                            ItemsSource="{Binding ScienceAuthorList}"
                                                            Style="{StaticResource Listbox_Request}">

                                                            <ListBox.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ListBox.ItemsPanel>
                                                            <ListBox.ItemContainerStyle>
                                                                <Style BasedOn="{StaticResource MaterialDesignFilterChipListBoxItem}" TargetType="ListBoxItem">
                                                                    <Setter Property="IsSelected" Value="{Binding IsSelected}" />
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Label Content="{Binding ScienceAuthorText}" Style="{StaticResource Label_Base}" />
                                                                        <i:Interaction.Triggers>
                                                                            <i:EventTrigger EventName="MouseDown">
                                                                                <i:InvokeCommandAction Command="{Binding Path=DataContext.ScienceAuthorListSelectedCommand, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}" />
                                                                            </i:EventTrigger>
                                                                        </i:Interaction.Triggers>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                        <TextBlock
                                                            Style="{StaticResource Style_Textbox_Error}"
                                                            Text="Bitte wählen Sie eine Mitwirkungsart aus"
                                                            Visibility="{Binding ErrorScienceAuthor, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <!--#endregion-->
                                                <!--#region Lehrtätigkeit; Visibilty: AnzeigEducation-->
                                                <StackPanel Visibility="{Binding AnzeigeEducation, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
                                                    <!--  Titel  -->
                                                    <StackPanel Style="{StaticResource Stackpanel_Vertical}">
                                                        <TextBox
                                                            MD:HintAssist.Hint="{Binding Hint_RequestTitel}"
                                                            Style="{StaticResource Textbox_Request}"
                                                            Text="{Binding RequestTitel}" />
                                                        <!--  ErrorValidation  -->
                                                        <TextBlock
                                                            Style="{StaticResource Style_Textbox_Error}"
                                                            Text="Bitte geben ein Thema ein"
                                                            Visibility="{Binding ErrorTitel, Converter={StaticResource BooleanToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <!--#region Auftraggeber-->
                                                    <StackPanel Style="{StaticResource Stackpanel_Vertical}">
