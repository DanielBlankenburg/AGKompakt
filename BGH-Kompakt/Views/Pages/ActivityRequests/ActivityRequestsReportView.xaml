<UserControl
    x:Class="BGH_Kompakt.Views.Pages.ActivityRequests.ActivityRequestsReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.ActivityRequests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nebentaetigkeiten="clr-namespace:BGH_Kompakt.ViewModel.Nebentaetigkeiten"
    d:DataContext="{d:DesignInstance Type=nebentaetigkeiten:ActivityRequestsReportViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Language="DE-De"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="MDCard_Report"
            BasedOn="{StaticResource MDCard_Master_Padding}"
            TargetType="MD:Card">
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style x:Key="Grid_Report_E1" TargetType="Grid">
            <Setter Property="Margin" Value="15,10,0,15" />
        </Style>
        <Style x:Key="Grid_Report_E0" TargetType="Grid">
            <Setter Property="Margin" Value="10,0" />
            <Setter Property="Width" Value="300" />
        </Style>
        <Style
            x:Key="Grid_Report_E0_0"
            BasedOn="{StaticResource Grid_Report_E0}"
            TargetType="Grid">
            <Setter Property="Background" Value="White" />
        </Style>
        <Style
            x:Key="Grid_Report_E0_1"
            BasedOn="{StaticResource Grid_Report_E0}"
            TargetType="Grid">
            <Setter Property="Background" Value="#fcfcfc" />
        </Style>
        <Style
            x:Key="textblock_ReportE1"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="5,5,0,0" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style
            x:Key="textblock_Label"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style
            x:Key="textblock_Ergebnis"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style
            x:Key="textbox_Datum"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,30,5" />
            <Setter Property="Width" Value="100" />
        </Style>
        <Style
            x:Key="Datepicker_Report"
            BasedOn="{StaticResource Datepicker_Base}"
            TargetType="{x:Type DatePicker}">
            <Setter Property="Margin" Value="0,5,30,5" />
            <Setter Property="Width" Value="130" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Style="{StaticResource Style_Textblock_Titel_Unter1}" Text="Abfragen" />
        <MD:Card Grid.Row="1" Style="{StaticResource MDCard_Report}">
            <StackPanel
                Grid.Row="1"
                Margin="10,0,0,0"
                Orientation="Horizontal">
                <DatePicker
                    MD:HintAssist.Hint="Beginn"
                    SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource Datepicker_Report}" />
                <DatePicker
                    MD:HintAssist.Hint="Ende"
                    SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource Datepicker_Report}" />
                <Button
                    Command="{Binding StartRequestCommand}"
                    Content="Abfrage starten"
                    Style="{StaticResource Button_Master}" />
            </StackPanel>
        </MD:Card>
        <MD:Card Grid.Row="2" Style="{StaticResource MDCard_Report}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" Orientation="Vertical">
                    <Grid Style="{StaticResource Grid_Report_E0_0}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Anzahl der Nebentätigkeiten" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzahl Richter" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzeigepflichtig" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Gehemigungspflichtig" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="{Binding JudgeCount, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="{Binding AnzeigeCount, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="{Binding GenehmigungCount, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Grid>
                    <Grid Style="{StaticResource Grid_Report_E0_1}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Durchschnitt der Stundenanzahl" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzeigepflichtig" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Gehemigungspflichtig" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 2" />
                        </Grid>
                    </Grid>
                    <Grid Style="{StaticResource Grid_Report_E0_0}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchste Stundenanzahl" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzeigepflichtig" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Gehemigungspflichtig" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 2" />
                        </Grid>
                    </Grid>
                    <Grid Style="{StaticResource Grid_Report_E0_1}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Durchschnitt Vergütung" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzeigepflichtig" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Gehemigungspflichtig" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 2" />
                        </Grid>
                    </Grid>
                    <Grid Style="{StaticResource Grid_Report_E0_0}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchste Gesamtvergütung" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzeigepflichtig" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Gehemigungspflichtig" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 2" />
                        </Grid>
                    </Grid>
                    <Grid Style="{StaticResource Grid_Report_E0_1}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchste Einzelvergütung" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzeigepflichtig" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Gehemigungspflichtig" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 2" />
                        </Grid>
                    </Grid>
                    <Grid Style="{StaticResource Grid_Report_E0_0}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchster Betrag im Stundenverhältnis" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Anzeigepflichtig" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="Gehemigungspflichtig" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 2" />
                        </Grid>
                    </Grid>
                    <Grid Style="{StaticResource Grid_Report_E0_1}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Überschreitung 40%-Grenze" />
                        <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="R6" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="R8" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="R9" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Style="{StaticResource textblock_Label}"
                                Text="R10" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 2" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 3" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                Style="{StaticResource textblock_Ergebnis}"
                                Text="Ergebnis 4" />
                        </Grid>
                    </Grid>

                </WrapPanel>

            </Grid>
        </MD:Card>
    </Grid>
</UserControl>
