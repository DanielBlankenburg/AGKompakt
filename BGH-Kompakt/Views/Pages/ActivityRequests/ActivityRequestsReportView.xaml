<UserControl
    x:Class="BGH_Kompakt.Views.Pages.ActivityRequests.ActivityRequestsReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MD="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:MW="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BGH_Kompakt.Views.Pages.ActivityRequests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nebentaetigkeiten="clr-namespace:BGH_Kompakt.ViewModel.Nebentaetigkeiten"
    d:DataContext="{d:DesignInstance Type=nebentaetigkeiten:ActivityRequestsReportViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    Language="DE-De"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="MDCard_Report"
            BasedOn="{StaticResource MDCard_Master_Padding}"
            TargetType="MD:Card">
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style
            x:Key="MDCard_Report_Expander"
            BasedOn="{StaticResource MDCard_Master}"
            TargetType="MD:Card">
            <Setter Property="Margin" Value="0,5,15,5" />
        </Style>
        <Style x:Key="Grid_Report_E1" TargetType="Grid">
            <Setter Property="Margin" Value="35,10,0,15" />
        </Style>
        <Style x:Key="Grid_Report_E0" TargetType="Grid">
            <Setter Property="Margin" Value="10,0" />
            <Setter Property="Width" Value="300" />
        </Style>
        <Style
            x:Key="Grid_Report_E0_0"
            BasedOn="{StaticResource Grid_Report_E0}"
            TargetType="Grid">
            <Setter Property="Background" Value="White" />
        </Style>
        <Style
            x:Key="Grid_Report_E0_1"
            BasedOn="{StaticResource Grid_Report_E0}"
            TargetType="Grid">
            <Setter Property="Background" Value="#fcfcfc" />
        </Style>
        <Style
            x:Key="textblock_ReportE1"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="5,5,0,0" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style
            x:Key="textblock_ReportR1"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style
            x:Key="textblock_Label"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style
            x:Key="textblock_Ergebnis"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style
            x:Key="textbox_Datum"
            BasedOn="{StaticResource Textbox_Base}"
            TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,30,5" />
            <Setter Property="Width" Value="100" />
        </Style>
        <Style
            x:Key="list_value"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,5,20,5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style
            x:Key="list_label"
            BasedOn="{StaticResource textblock_base}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,5" />
        </Style>
        <Style
            x:Key="Datepicker_Report"
            BasedOn="{StaticResource Datepicker_Base}"
            TargetType="{x:Type DatePicker}">
            <Setter Property="Margin" Value="0,5,30,5" />
            <Setter Property="Width" Value="130" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style
            x:Key="Expander"
            BasedOn="{StaticResource MaterialDesignExpander}"
            TargetType="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsExpanded" Value="True">
                    <Setter Property="Background" Value="{StaticResource BGHActivityRequestBackground}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!--<Style x:Key="MaterialDesignExpander_Compact" BasedOn="{StaticResource MaterialDesignExpander}" TargetType="Expander">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,12,0,12"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <ContentPresenter VerticalAlignment="Center" Margin="4,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>-->

    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="500" />
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource Style_Textblock_Titel_Unter1}" Text="Abfragen" />
        <MD:Card
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Style="{StaticResource MDCard_Report}">
            <StackPanel
                Grid.Row="1"
                Margin="10,0,0,0"
                Orientation="Horizontal">
                <DatePicker
                    MD:HintAssist.Hint="Beginn"
                    SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource Datepicker_Report}" />
                <DatePicker
                    MD:HintAssist.Hint="Ende"
                    SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource Datepicker_Report}" />
                <Button
                    Command="{Binding StartRequestCommand}"
                    Content="Abfrage starten"
                    Style="{StaticResource Button_Master}" />
            </StackPanel>
        </MD:Card>
        <MD:Card
            Grid.Row="2"
            Style="{StaticResource MDCard_Report}"
            Visibility="{Binding ShowReport, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <WrapPanel Orientation="Vertical">
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">
                        <Expander IsExpanded="{Binding IsExpandedReport1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Anzahl der Nebentätigkeiten" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzahl Richter" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzeigepflichtig" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Gehemigungspflichtig" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding JudgeCount, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding AnzeigeCount, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding GenehmigungCount, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">

                        <Expander IsExpanded="{Binding IsExpandedReport2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Durchschnitt der Stundenanzahl" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzeigepflichtig" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Gehemigungspflichtig" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding AnzeigeHoursAverage, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding GenehmigungHoursAverage, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">
                        <Expander IsExpanded="{Binding IsExpandedReport3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchste Stundenanzahl" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzeigepflichtig" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Gehemigungspflichtig" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding AnzeigeHoursMax, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding GenehmigungHoursMax, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">
                        <Expander IsExpanded="{Binding IsExpandedReport4, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Durchschnitt Vergütung" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzeigepflichtig" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Gehemigungspflichtig" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding AnzeigeAmountAverage, StringFormat=\{0:C\}, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding GenehmigungAmountAverage, StringFormat=\{0:C\}, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">
                        <Expander IsExpanded="{Binding IsExpandedReport5, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchste Gesamtvergütung" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzeigepflichtig" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Gehemigungspflichtig" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding AnzeigeAmountMax, StringFormat=\{0:C\}, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding GenehmigungAmountMax, StringFormat=\{0:C\}, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">
                        <Expander IsExpanded="{Binding IsExpandedReport6, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchste Einzelvergütung" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzeigepflichtig" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Gehemigungspflichtig" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding AnzeigeSingleAmountMax, StringFormat=\{0:C\}, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding GenehmigungSingleAmountMax, StringFormat=\{0:C\}, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">
                        <Expander IsExpanded="{Binding IsExpandedReport7, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Höchster Betrag im Stundenverhältnis" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Anzeigepflichtig" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="Gehemigungspflichtig" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding AnzeigeProportion.Proportion}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="{Binding GenehmigungProportion.Proportion}" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                    <MD:Card Style="{StaticResource MDCard_Report_Expander}">
                        <Expander IsExpanded="{Binding IsExpandedReport8, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Expander}">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="Überschreitung 40%-Grenze" />
                            </Expander.Header>
                            <Grid Grid.Row="1" Style="{StaticResource Grid_Report_E1}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="R6" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="R8" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="R9" />
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Style="{StaticResource textblock_Label}"
                                    Text="R10" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="Ergebnis" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="Ergebnis 2" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="Ergebnis 3" />
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Style="{StaticResource textblock_Ergebnis}"
                                    Text="Ergebnis 4" />
                            </Grid>
                        </Expander>
                    </MD:Card>
                </WrapPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button
                        Margin="0,0,15,0"
                        Command="{Binding ExpandAllCommand}"
                        Content="Alle ausklappen"
                        Style="{StaticResource Button_Master}" />
                    <Button
                        Margin="0,0,15,0"
                        Command="{Binding CollapseAllCommand}"
                        Content="Alle einklappen"
                        Style="{StaticResource Button_Master}" />
                    <Button
                        Width="170"
                        Command="{Binding CollapseAllARCommand}"
                        Style="{StaticResource Button_Master}"
                        ToolTip="Bericht erstellen">
                        <StackPanel Orientation="Horizontal">
                            <MD:PackIcon Padding="0" Kind="MicrosoftWord" />
                            <TextBlock
                                Margin="10,0,0,0"
                                Style="{StaticResource textblock_base}"
                                Text="Bericht erstellen" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </MD:Card>
        <MD:Card
            Grid.Row="2"
            Grid.Column="1"
            Style="{StaticResource MDCard_Report}"
            Visibility="{Binding ShowReport, Converter={StaticResource BoolToVisConverter}, UpdateSourceTrigger=PropertyChanged}">

            <TabControl Margin="0,0,0,10" Style="{StaticResource MahApps.Styles.TabControl}">
                <TabItem Header="Tätigkeiten pro Veranstalter">
                    <Grid Grid.Column="1" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ListBox
                            Grid.Row="1" 
                            ItemsSource="{Binding RequestsByClient}"
                            Style="{StaticResource MaterialDesignCardsListBox}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>

                                    <Expander Style="{StaticResource Expander}">
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="{Binding TypeName}" />
                                            </Grid>
                                        </Expander.Header>
                                        <Grid  Margin="40,0,0,10">
                                            <ItemsControl ItemsSource="{Binding Clients}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="10,2,0,2" Orientation="Horizontal">
                                                            <TextBlock
                                                                Width="300"
                                                                Style="{StaticResource textblock_Label}"
                                                                Text="{Binding ClientName}" />
                                                            <TextBlock
                                                                Width="100"
                                                                Style="{StaticResource textblock_Ergebnis}"
                                                                Text="{Binding Count}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Expander>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </Grid>
                </TabItem>
                <TabItem Header="Tätigkeiten pro Richter">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="AUto" />
                        </Grid.RowDefinitions>
                        <ListBox
                            Grid.Row="0"
                            Margin="0,10,0,0"
                            ItemsSource="{Binding RequestsByUser}"
                            ScrollViewer.CanContentScroll="False"
                            Style="{StaticResource MaterialDesignCardsListBox}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Expander Style="{StaticResource Expander}">
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource textblock_ReportE1}" Text="{Binding UserName}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource textblock_Label}"
                                                    Text="{Binding RequestCount}" />
                                            </Grid>
                                        </Expander.Header>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Margin="40,0,0,0">
                                                <TextBlock Style="{StaticResource textblock_ReportR1}" Text="Grunddaten:" />
                                                <Grid Margin="10,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource list_label}" Text="Gesamtvergütung:" />
                                                    <TextBlock Style="{StaticResource list_value}" Text="{Binding TotalAmount, StringFormat=\{0:C\}}" />
                                                </Grid>
                                                <Grid Margin="10,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource list_label}" Text="Gesamtstunden:" />
                                                    <TextBlock Style="{StaticResource list_value}" Text="{Binding TotalHours}" />
                                                </Grid>
                                            </StackPanel>
                                            <Border
                                                Grid.Row="1"
                                                Margin="0,15"
                                                Style="{StaticResource Expander_Border}" />
                                            <TextBlock
                                                Grid.Row="2"
                                                Margin="40,0,0,0"
                                                Style="{StaticResource textblock_ReportR1}"
                                                Text="Tätigkeiten:" />
                                            <ItemsControl
                                                Grid.Row="3"
                                                Margin="35,0,0,0"
                                                ItemsSource="{Binding Requests}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Expander
                                                            Background="{StaticResource BGHActivityRequestBackground}"
                                                            IsExpanded="{Binding UpdateSourceTrigger=PropertyChanged, Path=DataContext.IsExpanded, RelativeSource={RelativeSource AncestorLevel=1, Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                                                            Style="{StaticResource MaterialDesignExpander}">
                                                            <Expander.Header>
                                                                <TextBlock Style="{StaticResource textblock_base}" Text="{Binding ARTitel}" />
                                                            </Expander.Header>
                                                            <Grid Margin="40,0,0,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Style="{StaticResource list_label}" Text="Gesamtvergütung" />
                                                                    <TextBlock Style="{StaticResource list_value}" Text="{Binding Gesamtverguetung, StringFormat=\{0:C\}}" />
                                                                </Grid>
                                                                <Grid Grid.Row="1">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="100" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Style="{StaticResource list_label}" Text="Zeitaufwand" />
                                                                    <TextBlock
                                                                        Grid.Column="1"
                                                                        HorizontalAlignment="Right"
                                                                        Style="{StaticResource list_value}"
                                                                        Text="{Binding Gesamtzeitaufwand}" />
                                                                </Grid>
                                                                <Grid Grid.Row="2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="200" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Style="{StaticResource list_label}" Text="Auftraggeber" />
                                                                    <TextBlock Style="{StaticResource list_value}" Text="{Binding ActivityClient.ACName}" />
                                                                </Grid>
                                                                <Border Grid.Row="3" Style="{StaticResource Expander_Border}" />
                                                            </Grid>
                                                        </Expander>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Expander>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <!--<StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button
                                Margin="0,0,15,0"
                                Command="{Binding ExpandAllARCommand}"
                                Content="Alle Tätigkeiten Ausklappen"
                                Style="{StaticResource Button_Master}" />
                            <Button
                                Command="{Binding CollapseAllARCommand}"
                                Content="Alle Tätigkeiten Einklappen"
                                Style="{StaticResource Button_Master}" />
                        </StackPanel>-->
                    </Grid>
                </TabItem>
            </TabControl>



        </MD:Card>
    </Grid>
</UserControl>
